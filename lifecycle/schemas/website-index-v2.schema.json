{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/website-index-v2.schema.json",
  "title": "Atlas website-facing lifecycle index v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "authority", "generator_version",
    "generated_timestamp", "source_revision", "source_fingerprint", "records"
  ],
  "properties": {
    "schema_id": { "const": "atlas.lifecycle.website-index" },
    "schema_version": { "const": "2.0.0" },
    "authority": { "const": "GENERATED_NONCANONICAL_PROJECTION" },
    "generator_version": { "const": "0.2.0" },
    "generated_timestamp": { "type": "string", "format": "date-time" },
    "source_revision": { "$ref": "common-v1.schema.json#/$defs/git_sha" },
    "source_fingerprint": { "$ref": "common-v1.schema.json#/$defs/fingerprint" },
    "records": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "record_id", "record_type", "schema_version", "lifecycle_status",
          "record_revision", "project_ids", "operation_ids", "quest_ids",
          "candidate_quest_refs", "campaign", "mission", "gate",
          "related_record_ids", "summary", "current_position",
          "unresolved_blockers", "next_safe_action", "next_gate",
          "latest_feather_id", "evidence_references", "protected_warning",
          "promotion_readiness", "source_record_digest"
        ],
        "properties": {
          "record_id": { "$ref": "common-v1.schema.json#/$defs/stable_id" },
          "record_type": {
            "enum": ["FEATHER", "FEATHER_ARCHIVE", "GOLDEN_WING", "QUEST_EMBERLINE", "QUEST_CHECKPOINT", "SUNSET", "SUNRISE", "CONTINUITY", "LIFECYCLE_RECEIPT"]
          },
          "schema_version": { "type": "string", "pattern": "^[0-9]+[.][0-9]+[.][0-9]+$" },
          "lifecycle_status": { "type": "string", "minLength": 1, "maxLength": 64 },
          "record_revision": { "type": ["integer", "null"], "minimum": 0 },
          "project_ids": {
            "type": "array", "maxItems": 64, "uniqueItems": true,
            "items": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" }
          },
          "operation_ids": {
            "type": "array", "maxItems": 64, "uniqueItems": true,
            "items": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" }
          },
          "quest_ids": {
            "type": "array", "maxItems": 64, "uniqueItems": true,
            "items": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" }
          },
          "candidate_quest_refs": {
            "type": "array", "maxItems": 64, "uniqueItems": true,
            "items": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" }
          },
          "campaign": { "type": ["string", "null"], "maxLength": 256 },
          "mission": { "type": ["string", "null"], "maxLength": 256 },
          "gate": { "type": ["string", "null"], "maxLength": 256 },
          "related_record_ids": {
            "type": "array", "maxItems": 128, "uniqueItems": true,
            "items": { "$ref": "common-v1.schema.json#/$defs/stable_id" }
          },
          "summary": { "type": ["string", "null"], "maxLength": 4000 },
          "current_position": { "type": ["string", "null"], "maxLength": 4000 },
          "unresolved_blockers": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
          "next_safe_action": { "type": ["string", "null"], "maxLength": 4000 },
          "next_gate": { "type": ["string", "null"], "maxLength": 4000 },
          "latest_feather_id": {
            "oneOf": [
              { "type": "null" },
              { "type": "string", "pattern": "^FTR-[A-Z2-7]{26}$" }
            ]
          },
          "evidence_references": { "$ref": "common-v1.schema.json#/$defs/source_references" },
          "protected_warning": { "type": "boolean" },
          "promotion_readiness": { "type": ["string", "null"], "maxLength": 64 },
          "source_record_digest": { "$ref": "common-v1.schema.json#/$defs/fingerprint" }
        }
      }
    }
  }
}
