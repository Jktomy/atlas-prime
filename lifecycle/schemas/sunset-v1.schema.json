{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/sunset-v1.schema.json",
  "title": "Atlas Sunset checkpoint v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "record_id",
    "authority",
    "project_id",
    "operation_id",
    "quest_scope",
    "completion_assessment",
    "decisions",
    "open_items",
    "next_safe_action",
    "next_approval_gate",
    "latest_feather_id",
    "concurrency",
    "durable_source_references",
    "evidence_pointers",
    "protected_data"
  ],
  "properties": {
    "schema_id": {
      "const": "atlas.lifecycle.sunset"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "pattern": "^SUN-[A-Z2-7]{26}$"
    },
    "authority": {
      "enum": [
        "CANONICAL_RECORD",
        "NONCANONICAL_FIXTURE"
      ]
    },
    "project_id": {
      "$ref": "common-v1.schema.json#/$defs/atlas_identity"
    },
    "operation_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "common-v1.schema.json#/$defs/atlas_identity"
        }
      ]
    },
    "quest_scope": {
      "$ref": "common-v1.schema.json#/$defs/quest_scope"
    },
    "completion_assessment": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text"
    },
    "decisions": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text_list"
    },
    "open_items": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text_list"
    },
    "next_safe_action": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text"
    },
    "next_approval_gate": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text"
    },
    "latest_feather_id": {
      "type": "string",
      "pattern": "^FTR-[A-Z2-7]{26}$"
    },
    "concurrency": {
      "$ref": "common-v1.schema.json#/$defs/concurrency"
    },
    "durable_source_references": {
      "$ref": "common-v1.schema.json#/$defs/source_references"
    },
    "evidence_pointers": {
      "$ref": "common-v1.schema.json#/$defs/source_references"
    },
    "protected_data": {
      "$ref": "common-v1.schema.json#/$defs/protected_data"
    }
  }
}
