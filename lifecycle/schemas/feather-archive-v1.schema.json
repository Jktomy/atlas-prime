{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/feather-archive-v1.schema.json",
  "title": "Atlas Feather Archive v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "record_id", "authority", "feather_id",
    "archive_reason", "archive_pointer", "expected_feather_status",
    "concurrency", "protected_data"
  ],
  "properties": {
    "schema_id": { "const": "atlas.lifecycle.feather-archive" },
    "schema_version": { "const": "1.0.0" },
    "record_id": { "type": "string", "pattern": "^FAR-[A-Z2-7]{26}$" },
    "authority": { "enum": ["CANONICAL_RECORD", "NONCANONICAL_FIXTURE"] },
    "feather_id": { "type": "string", "pattern": "^FTR-[A-Z2-7]{26}$" },
    "archive_reason": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "archive_pointer": { "$ref": "common-v1.schema.json#/$defs/source_reference" },
    "expected_feather_status": { "enum": ["SEALED", "SUPERSEDED", "INVALIDATED"] },
    "concurrency": { "$ref": "common-v1.schema.json#/$defs/concurrency" },
    "protected_data": { "$ref": "common-v1.schema.json#/$defs/protected_data" }
  }
}
