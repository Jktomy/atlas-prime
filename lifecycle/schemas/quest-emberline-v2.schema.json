{
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/quest-emberline-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authority": {
      "enum": [
        "CANONICAL_RECORD",
        "NONCANONICAL_FIXTURE"
      ]
    },
    "concurrency": {
      "$ref": "common-v1.schema.json#/$defs/concurrency"
    },
    "current_entry_id": {
      "pattern": "^(?:Main|Side|Branched|Final)-(?:Emberline|Campaign|Mission|Gate)-[0-9]{3}$",
      "type": "string"
    },
    "current_position": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text"
    },
    "durable_source_references": {
      "$ref": "common-v1.schema.json#/$defs/source_references"
    },
    "journey_entries": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "active_direction": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "common-v1.schema.json#/$defs/bounded_text"
              }
            ]
          },
          "branched_from": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "pattern": "^(?:Main|Side|Branched|Final)-(?:Emberline|Campaign|Mission|Gate)-[0-9]{3}$",
                "type": "string"
              }
            ]
          },
          "entry_id": {
            "pattern": "^(?:Main|Side|Branched|Final)-(?:Emberline|Campaign|Mission|Gate)-[0-9]{3}$",
            "type": "string"
          },
          "entry_type": {
            "enum": [
              "MAIN",
              "SIDE",
              "BRANCHED",
              "FINAL"
            ]
          },
          "outcome": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "common-v1.schema.json#/$defs/bounded_text"
              }
            ]
          },
          "reason": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "common-v1.schema.json#/$defs/bounded_text"
              }
            ]
          },
          "returns_to": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "pattern": "^(?:Main|Side|Branched|Final)-(?:Emberline|Campaign|Mission|Gate)-[0-9]{3}$",
                "type": "string"
              }
            ]
          },
          "scope": {
            "enum": [
              "EMBERLINE",
              "CAMPAIGN",
              "MISSION",
              "GATE"
            ]
          },
          "sequence": {
            "maximum": 999,
            "minimum": 1,
            "type": "integer"
          },
          "summary": {
            "$ref": "common-v1.schema.json#/$defs/bounded_text"
          },
          "superseded_direction": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "common-v1.schema.json#/$defs/bounded_text"
              }
            ]
          }
        },
        "required": [
          "entry_id",
          "sequence",
          "entry_type",
          "scope",
          "summary",
          "reason",
          "branched_from",
          "returns_to",
          "superseded_direction",
          "active_direction",
          "outcome"
        ],
        "type": "object"
      },
      "maxItems": 256,
      "minItems": 1,
      "type": "array"
    },
    "latest_feather_id": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "pattern": "^FTR-[A-Z2-7]{26}$",
          "type": "string"
        }
      ]
    },
    "lineage_root_id": {
      "pattern": "^QEM-[A-Z2-7]{26}$",
      "type": "string"
    },
    "next_gate": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text"
    },
    "operation_ids": {
      "items": {
        "$ref": "common-v1.schema.json#/$defs/atlas_identity"
      },
      "maxItems": 64,
      "type": "array",
      "uniqueItems": true
    },
    "project_id": {
      "$ref": "common-v1.schema.json#/$defs/atlas_identity"
    },
    "protected_data": {
      "$ref": "common-v1.schema.json#/$defs/protected_data"
    },
    "quest_id": {
      "$ref": "common-v1.schema.json#/$defs/atlas_identity"
    },
    "quest_revision": {
      "minimum": 1,
      "type": "integer"
    },
    "quest_state": {
      "enum": [
        "IN_PROGRESS",
        "COMPLETE"
      ]
    },
    "record_id": {
      "pattern": "^QEM-[A-Z2-7]{26}$",
      "type": "string"
    },
    "revision_parent_digest": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "type": "string"
        }
      ]
    },
    "schema_id": {
      "const": "atlas.lifecycle.quest-emberline"
    },
    "schema_version": {
      "const": "2.0.0"
    },
    "unresolved_blockers": {
      "$ref": "common-v1.schema.json#/$defs/bounded_text_list"
    }
  },
  "required": [
    "schema_id",
    "schema_version",
    "record_id",
    "lineage_root_id",
    "authority",
    "quest_id",
    "project_id",
    "operation_ids",
    "quest_revision",
    "revision_parent_digest",
    "quest_state",
    "current_entry_id",
    "journey_entries",
    "current_position",
    "unresolved_blockers",
    "next_gate",
    "latest_feather_id",
    "concurrency",
    "durable_source_references",
    "protected_data"
  ],
  "title": "Atlas Living Quest Emberline v2",
  "type": "object"
}
