{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/continuity-v1.schema.json",
  "title": "Atlas continuity record v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "record_id", "authority", "recovery_reason",
    "sunset_id", "sunrise_id", "expected_main_sha", "observed_main_sha",
    "reconstruction_accuracy", "missing_sources", "protected_data"
  ],
  "properties": {
    "schema_id": { "const": "atlas.lifecycle.continuity" },
    "schema_version": { "const": "1.0.0" },
    "record_id": { "type": "string", "pattern": "^CON-[A-Z2-7]{26}$" },
    "authority": { "enum": ["CANONICAL_RECORD", "NONCANONICAL_FIXTURE"] },
    "recovery_reason": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "sunset_id": { "type": "string", "pattern": "^SUN-[A-Z2-7]{26}$" },
    "sunrise_id": { "type": "string", "pattern": "^SRI-[A-Z2-7]{26}$" },
    "expected_main_sha": { "$ref": "common-v1.schema.json#/$defs/git_sha" },
    "observed_main_sha": { "$ref": "common-v1.schema.json#/$defs/git_sha" },
    "reconstruction_accuracy": { "enum": ["EXACT", "PARTIAL", "FAILED"] },
    "missing_sources": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "protected_data": { "$ref": "common-v1.schema.json#/$defs/protected_data" }
  }
}
