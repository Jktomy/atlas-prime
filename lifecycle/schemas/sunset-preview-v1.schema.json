{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/sunset-preview-v1.schema.json",
  "title": "Atlas Sunset Preview v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "preview_id",
    "authority",
    "expected_main_sha",
    "project_id",
    "operation_id",
    "quest_scope",
    "campaign",
    "mission",
    "gate",
    "context_summary",
    "completion_assessment",
    "decisions",
    "open_items",
    "current_position",
    "unresolved_blockers",
    "next_safe_action",
    "next_approval_gate",
    "next_gate",
    "durable_source_references",
    "evidence_pointers",
    "protected_data",
    "lesson_harvest",
    "selected_route",
    "fallback_routes",
    "permitted_approval_modes",
    "default_approval_mode",
    "expected_records",
    "semantic_digest"
  ],
  "properties": {
    "schema_id": { "const": "atlas.lifecycle.sunset-preview" },
    "schema_version": { "const": "1.0.0" },
    "preview_id": { "type": "string", "pattern": "^SPV-[A-Z2-7]{26}$" },
    "authority": { "const": "PREVIEW_ONLY" },
    "expected_main_sha": { "$ref": "common-v1.schema.json#/$defs/git_sha" },
    "project_id": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" },
    "operation_id": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" },
    "quest_scope": { "$ref": "common-v1.schema.json#/$defs/quest_scope" },
    "campaign": { "type": ["string", "null"], "maxLength": 256 },
    "mission": { "type": ["string", "null"], "maxLength": 256 },
    "gate": { "type": ["string", "null"], "maxLength": 256 },
    "context_summary": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "completion_assessment": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "decisions": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "open_items": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "current_position": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "unresolved_blockers": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "next_safe_action": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "next_approval_gate": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "next_gate": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "durable_source_references": { "$ref": "common-v1.schema.json#/$defs/source_references" },
    "evidence_pointers": { "$ref": "common-v1.schema.json#/$defs/source_references" },
    "protected_data": { "$ref": "common-v1.schema.json#/$defs/protected_data" },
    "lesson_harvest": { "$ref": "lesson-harvest-v1.schema.json" },
    "selected_route": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" },
    "fallback_routes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" }
    },
    "permitted_approval_modes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "uniqueItems": true,
      "items": { "enum": ["STANDARD", "GODDESS_MODE", "GODDESS_MODE_SHARDBLADE"] }
    },
    "default_approval_mode": { "const": "STANDARD" },
    "expected_records": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feathers", "sunsets", "sunrises", "quest_emberlines", "quest_checkpoints"],
      "properties": {
        "feathers": { "const": 1 },
        "sunsets": { "const": 1 },
        "sunrises": { "const": 1 },
        "quest_emberlines": { "type": "integer", "minimum": 0, "maximum": 1 },
        "quest_checkpoints": { "type": "integer", "minimum": 0, "maximum": 1 }
      }
    },
    "semantic_digest": { "$ref": "common-v1.schema.json#/$defs/fingerprint" }
  }
}
