{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/lifecycle/schemas/sunset-request-v3.schema.json",
  "title": "Atlas approved Sunset request v3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "schema_version", "authority", "request_id", "expected_main_sha",
    "project_id", "operation_id", "quest_scope", "campaign", "mission", "gate",
    "context_summary", "completion_assessment", "decisions", "open_items",
    "current_position", "unresolved_blockers", "next_safe_action",
    "next_approval_gate", "next_gate", "durable_source_references",
    "evidence_pointers", "protected_data", "lesson_harvest", "preview_id",
    "preview_digest", "approval_id", "approval_digest", "carrier_id",
    "carrier_digest", "semantic_digest", "approval_mode", "permanence_mode"
  ],
  "properties": {
    "schema_id": { "const": "atlas.lifecycle.sunset-request" },
    "schema_version": { "const": "3.0.0" },
    "authority": { "const": "PUBLIC_CLEAN_REQUEST" },
    "request_id": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" },
    "expected_main_sha": { "$ref": "common-v1.schema.json#/$defs/git_sha" },
    "project_id": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" },
    "operation_id": { "$ref": "common-v1.schema.json#/$defs/atlas_identity" },
    "quest_scope": { "$ref": "common-v1.schema.json#/$defs/quest_scope" },
    "campaign": { "type": ["string", "null"], "maxLength": 256 },
    "mission": { "type": ["string", "null"], "maxLength": 256 },
    "gate": { "type": ["string", "null"], "maxLength": 256 },
    "context_summary": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "completion_assessment": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "decisions": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "open_items": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "current_position": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "unresolved_blockers": { "$ref": "common-v1.schema.json#/$defs/bounded_text_list" },
    "next_safe_action": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "next_approval_gate": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "next_gate": { "$ref": "common-v1.schema.json#/$defs/bounded_text" },
    "durable_source_references": { "$ref": "common-v1.schema.json#/$defs/source_references" },
    "evidence_pointers": { "$ref": "common-v1.schema.json#/$defs/source_references" },
    "protected_data": { "$ref": "common-v1.schema.json#/$defs/protected_data" },
    "lesson_harvest": { "$ref": "lesson-harvest-v1.schema.json" },
    "preview_id": { "type": "string", "pattern": "^SPV-[A-Z2-7]{26}$" },
    "preview_digest": { "$ref": "common-v1.schema.json#/$defs/fingerprint" },
    "approval_id": { "type": "string", "pattern": "^SAP-[A-Z2-7]{26}$" },
    "approval_digest": { "$ref": "common-v1.schema.json#/$defs/fingerprint" },
    "carrier_id": { "type": "string", "pattern": "^SCR-[A-Z2-7]{26}$" },
    "carrier_digest": { "$ref": "common-v1.schema.json#/$defs/fingerprint" },
    "semantic_digest": { "$ref": "common-v1.schema.json#/$defs/fingerprint" },
    "approval_mode": { "enum": ["STANDARD", "GODDESS_MODE", "GODDESS_MODE_SHARDBLADE"] },
    "permanence_mode": { "enum": ["MANUAL_MERGE", "SHARDBLADE"] }
  }
}
