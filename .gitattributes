# Atlas Prime deterministic text normalization
* text=auto

.gitattributes text eol=lf
.gitignore text eol=lf
*.md text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.sh text eol=lf
*.ps1 text eol=crlf

*.zip binary
*.bundle binary
