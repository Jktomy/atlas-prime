{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/shardblade-permanence-receipt-v1.schema.json",
  "title": "Prime Shardblade permanence action receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "attempt_id", "nonce", "request_id", "request_sha256", "approval_record_sha256", "request_reservation_sha256", "action", "executed_at", "repository", "pull_request", "base_sha", "head_sha", "tree_sha", "changed_paths_sha256", "prior_ready_receipt_sha256", "result", "error_code", "observed_pr_state", "observed_head_sha", "observed_tree_sha", "merge_commit_sha", "canonical_main_sha", "canonical_tree_sha", "mutation", "stop_point", "rollback"],
  "properties": {
    "schema_version": {"const": "atlas.shardblade-permanence-receipt.v1"},
    "receipt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "attempt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9._-]{16,160}$"},
    "request_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "approval_record_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "request_reservation_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "action": {"enum": ["READY", "MERGE"]},
    "executed_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "repository": {"const": "Jktomy/atlas-prime"},
    "pull_request": {"type": "integer", "minimum": 1},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "changed_paths_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "prior_ready_receipt_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "result": {"enum": ["SUCCESS", "REJECTED", "BLOCKED", "PARTIAL"]},
    "error_code": {"type": ["string", "null"], "maxLength": 120},
    "observed_pr_state": {"enum": ["DRAFT", "OPEN_READY", "MERGED", "UNKNOWN"]},
    "observed_head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "observed_tree_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "merge_commit_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "canonical_main_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "canonical_tree_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "mutation": {"type": "object", "additionalProperties": false, "required": ["ready", "merge", "candidate_modified", "head_changed"], "properties": {
      "ready": {"type": "boolean"}, "merge": {"type": "boolean"}, "candidate_modified": {"const": false}, "head_changed": {"const": false}
    }},
    "stop_point": {"enum": ["READY_READBACK", "MERGED_MAIN_READBACK", "PRE_MUTATION_REJECTION", "READBACK_ONLY_RECOVERY"]},
    "rollback": {"enum": ["CLOSE_PR_BEFORE_MERGE", "REVIEWED_REVERT_PR", "NO_MUTATION", "PRESERVE_STATE_AND_RECONCILE"]}
  }
}
