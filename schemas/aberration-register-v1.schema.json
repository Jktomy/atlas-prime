{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/aberration-register-v1.schema.json",
  "title": "Prime Aberration Register v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "register_id", "campaign", "gate", "gate_status", "input_sha256", "finding_sha256s", "records", "local_model", "promotion"],
  "properties": {
    "schema_version": {"const": "atlas.aberration-register.v1"},
    "register_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "campaign": {"const": "RP-C04"},
    "gate": {"const": "RESONANCE_EVIDENCE_RECONCILED"},
    "gate_status": {"const": "EVIDENCE_RECONCILED"},
    "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "finding_sha256s": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "records": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["claim_key", "classification", "finding_ids", "statement_sha256s", "athena_refraction", "disposition", "human_decision"], "properties": {
      "claim_key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"},
      "classification": {"enum": ["CONSENSUS", "CONFLICT", "NOVEL"]},
      "finding_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 128}},
      "statement_sha256s": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
      "athena_refraction": {"type": "object", "additionalProperties": false, "required": ["operator", "recommendation", "reason", "is_final"], "properties": {
        "operator": {"const": "Athena"}, "recommendation": {"enum": ["REVIEW_FOR_ACCEPTANCE", "INVESTIGATE_CONFLICT", "SEEK_SECOND_LANE"]},
        "reason": {"type": "string", "minLength": 1, "maxLength": 240}, "is_final": {"const": false}
      }},
      "disposition": {"const": "OPEN_HUMAN_REVIEW"},
      "human_decision": {"type": "null"}
    }}},
    "local_model": {"type": "object", "additionalProperties": false, "required": ["status", "runtime_proof_sha256", "finding_ids"], "properties": {
      "status": {"const": "BLOCKED_RUNTIME_PROOF_ABSENT"}, "runtime_proof_sha256": {"type": "null"},
      "finding_ids": {"type": "array", "maxItems": 0}
    }},
    "promotion": {"const": "NONE"}
  }
}
