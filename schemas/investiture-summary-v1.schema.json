{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/investiture-summary-v1.schema.json",
  "title": "Found Silverlight sanitized deterministic summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "ledger_id", "generation_id", "record_count", "head_sha256", "measurement_counts", "light_known_beu", "known_beu_subtotal", "total_investiture_beu", "complete_total_available", "summary_sha256"],
  "properties": {
    "schema_version": {"const": "atlas.investiture-summary.v1"},
    "ledger_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+){2,15}$"},
    "generation_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+){2,15}$"},
    "record_count": {"type": "integer", "minimum": 0},
    "head_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "measurement_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["MEASURED", "PARTIAL", "UNAVAILABLE", "ZERO_MODEL"],
      "properties": {
        "MEASURED": {"type": "integer", "minimum": 0},
        "PARTIAL": {"type": "integer", "minimum": 0},
        "UNAVAILABLE": {"type": "integer", "minimum": 0},
        "ZERO_MODEL": {"type": "integer", "minimum": 0}
      }
    },
    "light_known_beu": {
      "type": "object",
      "additionalProperties": false,
      "required": ["Spirallight", "Chromelight", "Emberlight"],
      "properties": {
        "Spirallight": {"type": "integer", "minimum": 0},
        "Chromelight": {"type": "integer", "minimum": 0},
        "Emberlight": {"type": "integer", "minimum": 0}
      }
    },
    "known_beu_subtotal": {"type": "integer", "minimum": 0},
    "total_investiture_beu": {"type": ["integer", "null"], "minimum": 0},
    "complete_total_available": {"type": "boolean"},
    "summary_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
