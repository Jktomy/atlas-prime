{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-prime.local/schemas/source-metadata-v1.schema.json",
  "title": "Atlas Prime Markdown Source Metadata v1",
  "description": "Schema for YAML front matter extracted from authored Atlas Prime Markdown and represented as JSON.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "atlas_id",
    "format_version",
    "status",
    "source_type",
    "authority_class",
    "owner_project",
    "owner_operation",
    "canonical_scope",
    "protected_level",
    "routes_from",
    "routes_to",
    "private_boundary",
    "evidence_boundary",
    "supersedes",
    "cleanup_path",
    "last_verified"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "atlas_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "minLength": 3,
      "maxLength": 200
    },
    "format_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "DRAFT",
        "PROPOSED",
        "ACTIVE",
        "SUPERSEDED",
        "RETIRED",
        "HISTORICAL",
        "GENERATED"
      ]
    },
    "source_type": {
      "enum": [
        "BOOTSTRAP",
        "CORE_DOCTRINE",
        "PROTOCOL",
        "STANDARD",
        "SPECIFICATION",
        "POLICY",
        "PROJECT",
        "OPERATION",
        "RUNBOOK",
        "TEMPLATE",
        "REFERENCE",
        "REGISTER_VIEW",
        "GENERATED_VIEW",
        "MIGRATION_RECORD",
        "HISTORICAL_RECORD",
        "TOOL_DOCUMENTATION"
      ]
    },
    "authority_class": {
      "enum": [
        "CANONICAL_AUTHORED_SOURCE",
        "STRUCTURED_AUTHORITATIVE_REGISTER",
        "GENERATED_OPERATIONAL_PROJECTION",
        "CONTINUITY_PROVENANCE",
        "TOOL_CONTRACT",
        "TOOL_IMPLEMENTATION",
        "MIGRATION_EVIDENCE",
        "HISTORICAL_REFERENCE",
        "PRIVATE_POINTER"
      ]
    },
    "owner_project": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "owner_operation": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        {
          "type": "null"
        }
      ]
    },
    "canonical_scope": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "protected_level": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "routes_from": {
      "$ref": "#/$defs/path_array"
    },
    "routes_to": {
      "$ref": "#/$defs/path_array"
    },
    "private_boundary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "evidence_boundary": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2000
    },
    "supersedes": {
      "$ref": "#/$defs/path_array"
    },
    "cleanup_path": {
      "type": "string",
      "minLength": 5,
      "maxLength": 2000
    },
    "last_verified": {
      "oneOf": [
        {
          "type": "string",
          "format": "date"
        },
        {
          "type": "null"
        }
      ]
    },
    "superseded_by": {
      "$ref": "#/$defs/path_array"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "GENERATED"
          }
        }
      },
      "then": {
        "properties": {
          "authority_class": {
            "const": "GENERATED_OPERATIONAL_PROJECTION"
          },
          "source_type": {
            "enum": [
              "GENERATED_VIEW",
              "REGISTER_VIEW"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_class": {
            "const": "GENERATED_OPERATIONAL_PROJECTION"
          }
        }
      },
      "then": {
        "properties": {
          "status": {
            "const": "GENERATED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "SUPERSEDED"
          }
        }
      },
      "then": {
        "required": [
          "superseded_by"
        ],
        "properties": {
          "superseded_by": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "repository_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$"
    },
    "path_array": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/repository_path"
      },
      "uniqueItems": true,
      "maxItems": 100
    }
  }
}
