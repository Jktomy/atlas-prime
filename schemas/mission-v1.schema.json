{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/schemas/mission-v1.schema.json",
  "title": "Atlas Mission Board Mission v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "issue_number",
    "mission_id",
    "mission_type",
    "mission_state",
    "created_at",
    "updated_at",
    "objective",
    "rationale_and_decisions",
    "owner",
    "relationships",
    "assigned_worker",
    "execution_identity",
    "dependencies",
    "public_clean_boundary",
    "acceptance_criteria",
    "next_safe_action",
    "effort_class",
    "queue_behavior",
    "canonical_source_status",
    "source_binding",
    "validation_review",
    "coppermind",
    "completion_proof",
    "rollback",
    "attempt_id"
  ],
  "properties": {
    "schema_version": {"const": "atlas.mission.v1"},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "issue_number": {"type": "integer", "minimum": 1},
    "mission_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
    "mission_type": {
      "enum": [
        "mission/sunset",
        "mission/quest",
        "mission/campaign",
        "mission/gate",
        "mission/controlled-burn",
        "mission/phoenix-burn",
        "mission/repair",
        "mission/research",
        "mission/migration",
        "mission/generated-refresh"
      ]
    },
    "mission_state": {
      "enum": [
        "CAPTURED",
        "TRIAGED",
        "READY",
        "IN_PROGRESS",
        "BLOCKED_RESUMABLE",
        "PR_OPEN",
        "VALIDATING",
        "READY_FOR_PERMANENCE",
        "CANONICAL",
        "COPPERMIND_ARCHIVED",
        "CLOSED"
      ]
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "objective": {"type": "string", "minLength": 1, "maxLength": 4096},
    "rationale_and_decisions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1, "maxLength": 4096},
      "maxItems": 64
    },
    "owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "operation"],
      "properties": {
        "project": {"type": "string", "minLength": 1, "maxLength": 128},
        "operation": {"type": "string", "minLength": 1, "maxLength": 128}
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": ["quest", "campaign", "gate"],
      "properties": {
        "quest": {"type": ["string", "null"], "maxLength": 160},
        "campaign": {"type": ["string", "null"], "maxLength": 160},
        "gate": {"type": ["string", "null"], "maxLength": 160}
      }
    },
    "assigned_worker": {"type": "string", "minLength": 1, "maxLength": 160},
    "execution_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["declared_worker", "credential_principal", "surface", "publisher"],
      "properties": {
        "declared_worker": {"type": "string", "minLength": 1, "maxLength": 160},
        "credential_principal": {"type": "string", "minLength": 1, "maxLength": 160},
        "surface": {"type": "string", "minLength": 1, "maxLength": 160},
        "publisher": {"type": "string", "minLength": 1, "maxLength": 160}
      }
    },
    "dependencies": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["relation", "repository", "mission_ref"],
        "properties": {
          "relation": {"enum": ["BLOCKS", "BLOCKED_BY", "PARALLEL_WITH", "NONBLOCKING_RELATED", "PARENT_OF", "CHILD_OF"]},
          "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
          "mission_ref": {"type": "string", "minLength": 1, "maxLength": 160}
        }
      }
    },
    "public_clean_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "sanitized_summary", "protected_pointer"],
      "properties": {
        "classification": {"const": "PUBLIC_CLEAN"},
        "sanitized_summary": {"type": "string", "minLength": 1, "maxLength": 4096},
        "protected_pointer": {"type": ["string", "null"], "pattern": "^protected://[A-Za-z0-9._/-]+$"}
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 64,
      "items": {"type": "string", "minLength": 1, "maxLength": 2048}
    },
    "next_safe_action": {"type": "string", "minLength": 1, "maxLength": 4096},
    "effort_class": {"enum": ["BEU_0", "BEU_1", "BEU_2", "BEU_3", "BEU_5", "BEU_8", "UNKNOWN"]},
    "queue_behavior": {"enum": ["TERMINAL_ON_BLOCK", "CONTINUE_IF_BLOCKED_RESUMABLE"]},
    "canonical_source_status": {"enum": ["PHOENIX_PENDING", "NO_SOURCE_CHANGE_REQUIRED", "PR_OPEN", "MERGED_PENDING_READBACK", "CANONICAL"]},
    "source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_sha", "branch", "pull_request", "expected_head", "changed_paths", "changed_paths_digest", "merged_commit"],
      "properties": {
        "base_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
        "branch": {"type": ["string", "null"], "maxLength": 255},
        "pull_request": {"type": ["integer", "null"], "minimum": 1},
        "expected_head": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
        "changed_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?![A-Za-z]:/)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}},
        "changed_paths_digest": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "merged_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"}
      }
    },
    "validation_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["validation_status", "review_status", "strikeforce_status", "receipt_refs"],
      "properties": {
        "validation_status": {"enum": ["NOT_STARTED", "PENDING", "PASS", "FAIL", "UNREADABLE"]},
        "review_status": {"enum": ["NOT_STARTED", "PENDING", "RESOLVED", "BLOCKING"]},
        "strikeforce_status": {"enum": ["NOT_RUN", "GREEN", "YELLOW", "RED"]},
        "receipt_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 512}}
      }
    },
    "coppermind": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reference", "archive_timestamp", "archive_package"],
      "properties": {
        "status": {"enum": ["PENDING", "PACKAGE_READY", "ARCHIVED", "NOT_APPLICABLE"]},
        "reference": {"type": ["string", "null"], "maxLength": 512},
        "archive_timestamp": {"type": ["string", "null"], "format": "date-time"},
        "archive_package": {
          "oneOf": [
            {"type": "null"},
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["mission_identity", "objective", "final_status", "decisions", "relationships", "worker_identity", "branch", "pull_request", "merged_commit", "changed_paths", "validation_summary", "receipts", "lesson_harvest", "unresolved_follow_up", "rollback", "canonical_readback", "archive_timestamp"],
              "properties": {
                "mission_identity": {"type": "string", "minLength": 1},
                "objective": {"type": "string", "minLength": 1},
                "final_status": {"type": "string", "minLength": 1},
                "decisions": {"type": "array", "items": {"type": "string"}},
                "relationships": {"type": "array", "items": {"type": "string"}},
                "worker_identity": {"type": "string", "minLength": 1},
                "branch": {"type": ["string", "null"]},
                "pull_request": {"type": ["integer", "null"]},
                "merged_commit": {"type": ["string", "null"]},
                "changed_paths": {"type": "array", "items": {"type": "string"}},
                "validation_summary": {"type": "string", "minLength": 1},
                "receipts": {"type": "array", "items": {"type": "string"}},
                "lesson_harvest": {"type": "array", "items": {"type": "string"}},
                "unresolved_follow_up": {"type": "array", "items": {"type": "string"}},
                "rollback": {"type": "string", "minLength": 1},
                "canonical_readback": {"type": "string", "minLength": 1},
                "archive_timestamp": {"type": ["string", "null"], "format": "date-time"}
              }
            }
          ]
        }
      }
    },
    "completion_proof": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 1024}},
    "rollback": {"type": "string", "minLength": 1, "maxLength": 4096},
    "attempt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
    "sunset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["conversation_summary", "exact_unfinished_work", "blockers", "lesson_harvest_dispositions", "golden_wing_candidate_disposition", "record_plan", "phoenix_processing_pending", "archival_status", "truth_state"],
      "properties": {
        "conversation_summary": {"type": "string", "minLength": 1, "maxLength": 8192},
        "exact_unfinished_work": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "blockers": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "lesson_harvest_dispositions": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "golden_wing_candidate_disposition": {"type": "string", "minLength": 1},
        "record_plan": {"type": "string", "minLength": 1},
        "phoenix_processing_pending": {"type": "boolean"},
        "archival_status": {"enum": ["PENDING", "PACKAGE_READY", "ARCHIVED", "NOT_APPLICABLE"]},
        "truth_state": {"enum": ["SUNSET_CAPTURED", "PHOENIX_PENDING", "PR_OPEN", "MERGED_PENDING_READBACK", "CANONICAL_READBACK_COMPLETE", "SUNSET COMPLETE"]}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"mission_type": {"const": "mission/sunset"}}},
      "then": {"required": ["sunset"]},
      "else": {"not": {"required": ["sunset"]}}
    }
  ]
}
