{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/resonance-finding-v1.schema.json",
  "title": "Prime sealed independent finding v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "finding_id", "lane_id", "input_sha256", "claim_key", "statement", "evidence", "confidence", "agent_identity", "independence", "status"],
  "properties": {
    "schema_version": {"const": "atlas.resonance-finding.v1"},
    "finding_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "lane_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "claim_key": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"},
    "statement": {"type": "string", "minLength": 1, "maxLength": 2000},
    "evidence": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["evidence_type", "source", "sha256"], "properties": {
      "evidence_type": {"enum": ["REPOSITORY_FILE", "SYNTHETIC_FIXTURE"]},
      "source": {"type": "string", "minLength": 1, "maxLength": 300}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    }}},
    "confidence": {"enum": ["LOW", "MEDIUM", "HIGH"]},
    "agent_identity": {"type": "object", "additionalProperties": false, "required": ["agent_id", "provider", "model", "stormlight"], "properties": {
      "agent_id": {"type": "string", "minLength": 1, "maxLength": 128}, "provider": {"type": "string", "minLength": 1, "maxLength": 80},
      "model": {"type": "string", "minLength": 1, "maxLength": 120}, "stormlight": {"enum": ["CLOUD", "LOCAL", "HYBRID", "NONE"]}
    }} ,
    "independence": {"type": "object", "additionalProperties": false, "required": ["prior_lane_visibility", "sealed_at", "warrant_id"], "properties": {
      "prior_lane_visibility": {"const": false}, "sealed_at": {"type": "string", "minLength": 1, "maxLength": 40},
      "warrant_id": {"type": "string", "minLength": 1, "maxLength": 128}
    }},
    "status": {"const": "SEALED_CANDIDATE"}
  }
}
