{
  "$id": "https://atlas-prime.local/schemas/spear/spear-execution-receipt-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actor": {
      "oneOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "approval_reference": {
      "oneOf": [
        {
          "maxLength": 1000,
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "authority": {
      "additionalProperties": false,
      "properties": {
        "cutover_authorized": {
          "const": false
        },
        "deletion_authorized": {
          "const": false
        },
        "draft_pr_only": {
          "const": true
        },
        "merge_authorized": {
          "const": false
        },
        "migration_authorized": {
          "const": false
        },
        "promotion_authorized": {
          "const": false
        }
      },
      "required": [
        "draft_pr_only",
        "merge_authorized",
        "deletion_authorized",
        "migration_authorized",
        "promotion_authorized",
        "cutover_authorized"
      ],
      "type": "object"
    },
    "base_branch": {
      "const": "main"
    },
    "base_commit": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "blocker_codes": {
      "items": {
        "pattern": "^[A-Z0-9_]+$",
        "type": "string"
      },
      "maxItems": 100,
      "type": "array",
      "uniqueItems": true
    },
    "branch": {
      "oneOf": [
        {
          "pattern": "^spear/[0-9]{8}-[0-9]{3}-[a-f0-9]{8}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "changed_files": {
      "items": {
        "maxLength": 500,
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$",
        "type": "string"
      },
      "maxItems": 5,
      "type": "array",
      "uniqueItems": true
    },
    "commit_sha": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "contract_identities": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "git_blob_sha": {
            "pattern": "^[0-9a-f]{40}$",
            "type": "string"
          },
          "path": {
            "maxLength": 500,
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$",
            "type": "string"
          },
          "repository_commit": {
            "pattern": "^[0-9a-f]{40}$",
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          }
        },
        "required": [
          "path",
          "repository_commit",
          "git_blob_sha",
          "sha256"
        ],
        "type": "object"
      },
      "maxItems": 20,
      "type": "array"
    },
    "event": {
      "oneOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "file_identities": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "enum": [
              "CREATE_FILE",
              "REPLACE_FILE_FULL"
            ]
          },
          "new_content_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "old_blob_sha": {
            "oneOf": [
              {
                "pattern": "^[0-9a-f]{40}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "path": {
            "maxLength": 500,
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$",
            "type": "string"
          }
        },
        "required": [
          "action",
          "path",
          "old_blob_sha",
          "new_content_sha256"
        ],
        "type": "object"
      },
      "maxItems": 5,
      "type": "array"
    },
    "last_completed_gate": {
      "enum": [
        "NONE",
        "CONTEXT_VALIDATED",
        "ENVELOPE_VALIDATED",
        "PLAN_VALIDATED",
        "BASE_REVERIFIED",
        "BRANCH_CREATED",
        "COMMIT_CREATED",
        "BRANCH_PUSHED",
        "PR_REQUESTED",
        "PR_VERIFIED"
      ]
    },
    "manifest_sha256": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "packet_id": {
      "oneOf": [
        {
          "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "packet_transport_sha256": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "preview_sha256": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "protected_scan_categories": {
      "items": {
        "pattern": "^[a-z0-9_]+$",
        "type": "string"
      },
      "maxItems": 100,
      "type": "array",
      "uniqueItems": true
    },
    "pull_request_number": {
      "oneOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "pull_request_url": {
      "oneOf": [
        {
          "format": "uri",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "receipt_version": {
      "const": "1.0"
    },
    "redaction_state": {
      "const": "PROTECTED_VALUES_REDACTED"
    },
    "repository": {
      "const": "Jktomy/atlas-prime"
    },
    "run_attempt": {
      "minLength": 1,
      "type": "string"
    },
    "run_id": {
      "minLength": 1,
      "type": "string"
    },
    "transaction_state": {
      "enum": [
        "BLOCKED_BEFORE_PLAN",
        "BLOCKED_IN_PLAN",
        "BLOCKED_BEFORE_BRANCH",
        "BLOCKED_BEFORE_PUSH",
        "BRANCH_PUSHED_PR_MISSING",
        "PR_STATE_UNCERTAIN",
        "DRAFT_PR_CREATED",
        "EXISTING_TRANSACTION_RETURNED",
        "FAILED_WITH_RECEIPT"
      ]
    },
    "tree_sha": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "validation_results": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 200,
      "type": "array"
    },
    "warning_codes": {
      "items": {
        "pattern": "^[A-Z0-9_]+$",
        "type": "string"
      },
      "maxItems": 100,
      "type": "array",
      "uniqueItems": true
    },
    "workflow_sha": {
      "oneOf": [
        {
          "pattern": "^[0-9a-f]{40}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "receipt_version",
    "transaction_state",
    "last_completed_gate",
    "repository",
    "base_branch",
    "base_commit",
    "packet_id",
    "packet_transport_sha256",
    "manifest_sha256",
    "preview_sha256",
    "approval_reference",
    "actor",
    "event",
    "workflow_sha",
    "run_id",
    "run_attempt",
    "changed_files",
    "branch",
    "commit_sha",
    "tree_sha",
    "pull_request_number",
    "pull_request_url",
    "contract_identities",
    "file_identities",
    "validation_results",
    "warning_codes",
    "blocker_codes",
    "protected_scan_categories",
    "redaction_state",
    "authority"
  ],
  "title": "Athena's Spear S1 Attempt Receipt v1",
  "type": "object"
}
