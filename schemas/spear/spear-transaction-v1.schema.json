{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-prime.local/schemas/spear/spear-transaction-v1.schema.json",
  "title": "Runner-neutral Spear Transaction v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "transaction_version",
    "transaction_id",
    "mission_id",
    "title",
    "controlling_preview",
    "build_authority",
    "repository_subtransactions",
    "candidate_set_sha256",
    "required_tests",
    "noctua_profile",
    "cross_repository_order",
    "recovery",
    "forbidden_actions"
  ],
  "properties": {
    "transaction_version": {
      "const": "1.0"
    },
    "transaction_id": {
      "type": "string",
      "pattern": "^spear-tx-[a-z0-9][a-z0-9-]{6,100}$"
    },
    "mission_id": {
      "type": "string",
      "pattern": "^atlas-[a-z0-9][a-z0-9.-]{6,120}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "controlling_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preview_id",
        "preview_sha256",
        "approved_by",
        "approval_reference"
      ],
      "properties": {
        "preview_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "preview_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "approved_by": {
          "const": "JAYSON"
        },
        "approval_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        }
      }
    },
    "build_authority": {
      "$ref": "#/$defs/authority_record"
    },
    "repository_subtransactions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "$ref": "#/$defs/repository_subtransaction"
      },
      "uniqueItems": true
    },
    "candidate_set_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "required_tests": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "uniqueItems": true
    },
    "noctua_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile_id",
        "profile_version",
        "path",
        "sha256"
      ],
      "properties": {
        "profile_id": {
          "const": "noctua.spear-transaction.v1"
        },
        "profile_version": {
          "const": "1.0"
        },
        "path": {
          "const": "profiles/noctua/spear-transaction-v1.json"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "cross_repository_order": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
      },
      "uniqueItems": true
    },
    "recovery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preserve_partial_state",
        "blind_retry_allowed",
        "cleanup_allowed",
        "recognized_states"
      ],
      "properties": {
        "preserve_partial_state": {
          "const": true
        },
        "blind_retry_allowed": {
          "const": false
        },
        "cleanup_allowed": {
          "const": false
        },
        "recognized_states": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "enum": [
              "NOT_STARTED",
              "LOCAL_VALIDATION_COMPLETE",
              "BRANCH_CREATED",
              "COMMIT_CREATED",
              "COMMIT_PUSHED",
              "BRANCH_PUSHED_PR_MISSING",
              "PR_STATE_UNCERTAIN",
              "DRAFT_PR_VERIFIED",
              "PARTIAL_REPOSITORY_SUCCESS",
              "MERGED_READBACK_INCOMPLETE",
              "COMPLETE"
            ]
          }
        }
      }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "DIRECT_MAIN_WRITE",
          "FORCE_PUSH",
          "AUTO_MERGE",
          "MERGE",
          "BRANCH_DELETE",
          "PR_CLOSE",
          "RESET_SUCCESSFUL_STATE",
          "DUPLICATE_PR",
          "SCOPE_EXPANSION",
          "S1_ACTIVATION",
          "ARTEMIS_ACTIVATION",
          "MIGRATION",
          "PROMOTION",
          "RETIREMENT",
          "EVIDENCE_DELETION",
          "GOOGLE_DRIVE_MUTATION",
          "CUTOVER"
        ]
      }
    }
  },
  "allOf": [
    {
      "properties": {
        "build_authority": {
          "properties": {
            "stage": {
              "const": "BUILD"
            },
            "merge_authorized": {
              "const": false
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha1": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "authority_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_version",
        "authority_id",
        "stage",
        "granted_by",
        "approval_reference",
        "permitted_actions",
        "denied_actions",
        "merge_authorized",
        "exact_target_binding"
      ],
      "properties": {
        "authority_version": {
          "const": "1.0"
        },
        "authority_id": {
          "type": "string",
          "pattern": "^authority-[a-z0-9][a-z0-9-]{6,100}$"
        },
        "stage": {
          "enum": [
            "BUILD",
            "EXECUTE"
          ]
        },
        "granted_by": {
          "const": "JAYSON"
        },
        "approval_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "permitted_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "VERIFY_STATE",
              "WRITE_EXACT_CANDIDATES",
              "CREATE_BRANCH",
              "CREATE_COMMIT",
              "PUSH_BRANCH",
              "CREATE_DRAFT_PR",
              "READBACK_DRAFT_PR",
              "EMIT_BUILD_RECEIPT",
              "VERIFY_AUDITED_HEADS",
              "MERGE_APPROVED_PR",
              "READBACK_MAIN",
              "EMIT_EXECUTE_RECEIPT"
            ]
          }
        },
        "denied_actions": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "DIRECT_MAIN_WRITE",
              "FORCE_PUSH",
              "AUTO_MERGE",
              "UNAPPROVED_MERGE",
              "BRANCH_DELETE",
              "PR_CLOSE",
              "SCOPE_EXPANSION",
              "S1_ACTIVATION",
              "ARTEMIS_ACTIVATION",
              "MIGRATION",
              "PROMOTION",
              "RETIREMENT",
              "EVIDENCE_DELETION",
              "GOOGLE_DRIVE_MUTATION",
              "CUTOVER"
            ]
          }
        },
        "merge_authorized": {
          "type": "boolean"
        },
        "exact_target_binding": {
          "$ref": "#/$defs/sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "stage": {
                "const": "BUILD"
              }
            },
            "required": [
              "stage"
            ]
          },
          "then": {
            "properties": {
              "merge_authorized": {
                "const": false
              },
              "permitted_actions": {
                "not": {
                  "contains": {
                    "const": "MERGE_APPROVED_PR"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "stage": {
                "const": "EXECUTE"
              }
            },
            "required": [
              "stage"
            ]
          },
          "then": {
            "properties": {
              "merge_authorized": {
                "const": true
              },
              "permitted_actions": {
                "contains": {
                  "const": "MERGE_APPROVED_PR"
                }
              }
            }
          }
        }
      ]
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "path",
        "payload_path",
        "content_sha256",
        "git_blob_sha1",
        "bytes",
        "source_type"
      ],
      "properties": {
        "action": {
          "enum": [
            "CREATE_FILE",
            "REPLACE_FILE_FULL"
          ]
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500,
          "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
        },
        "payload_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 600
        },
        "expected_state": {
          "const": "ABSENT"
        },
        "expected_blob_sha": {
          "$ref": "#/$defs/sha1"
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "git_blob_sha1": {
          "$ref": "#/$defs/sha1"
        },
        "bytes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1048576
        },
        "source_type": {
          "enum": [
            "AUTHORED_SOURCE",
            "TOOL_CONTRACT",
            "NOCTUA_PROFILE",
            "VALID_FIXTURE",
            "INVALID_FIXTURE"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "CREATE_FILE"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "expected_state"
            ],
            "not": {
              "required": [
                "expected_blob_sha"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "REPLACE_FILE_FULL"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "required": [
              "expected_blob_sha"
            ],
            "not": {
              "required": [
                "expected_state"
              ]
            }
          }
        }
      ]
    },
    "repository_subtransaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "base_branch",
        "expected_base_commit",
        "deterministic_branch",
        "commit_message",
        "pull_request",
        "operations",
        "stop_before_merge"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "base_branch": {
          "const": "main"
        },
        "expected_base_commit": {
          "$ref": "#/$defs/sha1"
        },
        "deterministic_branch": {
          "type": "string",
          "pattern": "^source/[a-z0-9][a-z0-9/_-]{6,150}$"
        },
        "commit_message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        },
        "pull_request": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "title",
            "body_sha256",
            "base",
            "head",
            "draft"
          ],
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1,
              "maxLength": 160
            },
            "body_sha256": {
              "$ref": "#/$defs/sha256"
            },
            "base": {
              "const": "main"
            },
            "head": {
              "type": "string",
              "pattern": "^source/[a-z0-9][a-z0-9/_-]{6,150}$"
            },
            "draft": {
              "const": true
            }
          }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 40,
          "items": {
            "$ref": "#/$defs/operation"
          }
        },
        "stop_before_merge": {
          "const": true
        }
      }
    }
  }
}
