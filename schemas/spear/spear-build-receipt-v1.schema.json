{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-prime.local/schemas/spear/spear-build-receipt-v1.schema.json",
  "title": "Spear Build Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "receipt_version",
    "receipt_id",
    "stage",
    "transaction_id",
    "mission_id",
    "arrow_id",
    "runner",
    "authority",
    "package_sha256",
    "candidate_set_sha256",
    "result",
    "last_completed_gate",
    "repository_results",
    "diagnostics_redacted",
    "forbidden_actions_confirmed",
    "emitted_at"
  ],
  "properties": {
    "receipt_version": {
      "const": "1.0"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^build-receipt-[a-z0-9][a-z0-9-]{6,120}$"
    },
    "stage": {
      "const": "BUILD"
    },
    "transaction_id": {
      "type": "string",
      "pattern": "^spear-tx-[a-z0-9][a-z0-9-]{6,100}$"
    },
    "mission_id": {
      "type": "string",
      "pattern": "^atlas-[a-z0-9][a-z0-9.-]{6,120}$"
    },
    "arrow_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 200
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter",
        "operator"
      ],
      "properties": {
        "adapter": {
          "enum": [
            "GITHUB_NATIVE_SPEAR",
            "ARTEMIS_BOW"
          ]
        },
        "operator": {
          "enum": [
            "ATHENA",
            "JAYSON",
            "ARTEMIS_LOCAL_OPERATOR"
          ]
        }
      }
    },
    "authority": {
      "$ref": "#/$defs/authority"
    },
    "package_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "candidate_set_sha256": {
      "$ref": "#/$defs/sha256"
    },
    "result": {
      "enum": [
        "PASS",
        "BLOCKED",
        "PARTIAL",
        "FAILED_WITH_RECEIPT"
      ]
    },
    "last_completed_gate": {
      "enum": [
        "NOT_STARTED",
        "LOCAL_VALIDATION_COMPLETE",
        "BRANCH_CREATED",
        "COMMIT_CREATED",
        "COMMIT_PUSHED",
        "BRANCH_PUSHED_PR_MISSING",
        "PR_STATE_UNCERTAIN",
        "DRAFT_PR_VERIFIED",
        "PARTIAL_REPOSITORY_SUCCESS",
        "COMPLETE"
      ]
    },
    "repository_results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "repository",
          "expected_base_commit",
          "observed_base_commit",
          "branch",
          "changed_files",
          "repository_result"
        ],
        "properties": {
          "repository": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
          },
          "expected_base_commit": {
            "$ref": "#/$defs/sha1"
          },
          "observed_base_commit": {
            "$ref": "#/$defs/sha1"
          },
          "branch": {
            "type": [
              "string",
              "null"
            ]
          },
          "commit_sha": {
            "oneOf": [
              {
                "$ref": "#/$defs/sha1"
              },
              {
                "type": "null"
              }
            ]
          },
          "changed_files": {
            "type": "array",
            "maxItems": 40,
            "items": {
              "$ref": "#/$defs/changed_file"
            }
          },
          "pull_request": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "number",
                  "url",
                  "base",
                  "head",
                  "head_sha",
                  "draft"
                ],
                "properties": {
                  "number": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "base": {
                    "const": "main"
                  },
                  "head": {
                    "type": "string",
                    "pattern": "^source/"
                  },
                  "head_sha": {
                    "$ref": "#/$defs/sha1"
                  },
                  "draft": {
                    "const": true
                  }
                }
              },
              {
                "type": "null"
              }
            ]
          },
          "repository_result": {
            "enum": [
              "PASS",
              "BLOCKED",
              "PARTIAL",
              "FAILED_WITH_RECEIPT"
            ]
          }
        }
      }
    },
    "diagnostics_redacted": {
      "const": true
    },
    "diagnostics": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "string",
        "maxLength": 1000
      }
    },
    "forbidden_actions_confirmed": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": [
          "NO_DIRECT_MAIN_WRITE",
          "NO_FORCE_PUSH",
          "NO_AUTO_MERGE",
          "NO_MERGE",
          "NO_BRANCH_DELETE",
          "NO_PR_CLOSE",
          "NO_SCOPE_EXPANSION",
          "NO_S1_ACTIVATION",
          "NO_ARTEMIS_ACTIVATION",
          "NO_MIGRATION",
          "NO_PROMOTION",
          "NO_RETIREMENT",
          "NO_EVIDENCE_DELETION",
          "NO_GOOGLE_DRIVE_MUTATION",
          "NO_CUTOVER"
        ]
      }
    },
    "emitted_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "properties": {
        "authority": {
          "properties": {
            "stage": {
              "const": "BUILD"
            },
            "merge_authorized": {
              "const": false
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "result": {
            "const": "PASS"
          }
        },
        "required": [
          "result"
        ]
      },
      "then": {
        "properties": {
          "last_completed_gate": {
            "enum": [
              "DRAFT_PR_VERIFIED",
              "COMPLETE"
            ]
          },
          "repository_results": {
            "items": {
              "properties": {
                "repository_result": {
                  "const": "PASS"
                },
                "branch": {
                  "type": "string"
                },
                "commit_sha": {
                  "$ref": "#/$defs/sha1"
                },
                "pull_request": {
                  "type": "object"
                }
              },
              "required": [
                "commit_sha",
                "pull_request"
              ]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "sha1": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority_version",
        "authority_id",
        "stage",
        "granted_by",
        "approval_reference",
        "permitted_actions",
        "denied_actions",
        "merge_authorized",
        "exact_target_binding"
      ],
      "properties": {
        "authority_version": {
          "const": "1.0"
        },
        "authority_id": {
          "type": "string",
          "pattern": "^authority-[a-z0-9][a-z0-9-]{6,100}$"
        },
        "stage": {
          "enum": [
            "BUILD",
            "EXECUTE"
          ]
        },
        "granted_by": {
          "const": "JAYSON"
        },
        "approval_reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "permitted_actions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "VERIFY_STATE",
              "WRITE_EXACT_CANDIDATES",
              "CREATE_BRANCH",
              "CREATE_COMMIT",
              "PUSH_BRANCH",
              "CREATE_DRAFT_PR",
              "READBACK_DRAFT_PR",
              "EMIT_BUILD_RECEIPT",
              "VERIFY_AUDITED_HEADS",
              "MERGE_APPROVED_PR",
              "READBACK_MAIN",
              "EMIT_EXECUTE_RECEIPT"
            ]
          }
        },
        "denied_actions": {
          "type": "array",
          "minItems": 8,
          "uniqueItems": true,
          "items": {
            "enum": [
              "DIRECT_MAIN_WRITE",
              "FORCE_PUSH",
              "AUTO_MERGE",
              "UNAPPROVED_MERGE",
              "BRANCH_DELETE",
              "PR_CLOSE",
              "SCOPE_EXPANSION",
              "S1_ACTIVATION",
              "ARTEMIS_ACTIVATION",
              "MIGRATION",
              "PROMOTION",
              "RETIREMENT",
              "EVIDENCE_DELETION",
              "GOOGLE_DRIVE_MUTATION",
              "CUTOVER"
            ]
          }
        },
        "merge_authorized": {
          "type": "boolean"
        },
        "exact_target_binding": {
          "$ref": "#/$defs/sha256"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "stage": {
                "const": "BUILD"
              }
            },
            "required": [
              "stage"
            ]
          },
          "then": {
            "properties": {
              "merge_authorized": {
                "const": false
              },
              "permitted_actions": {
                "not": {
                  "contains": {
                    "const": "MERGE_APPROVED_PR"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "stage": {
                "const": "EXECUTE"
              }
            },
            "required": [
              "stage"
            ]
          },
          "then": {
            "properties": {
              "merge_authorized": {
                "const": true
              },
              "permitted_actions": {
                "contains": {
                  "const": "MERGE_APPROVED_PR"
                }
              }
            }
          }
        }
      ]
    },
    "changed_file": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "content_sha256",
        "git_blob_sha1"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "content_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "git_blob_sha1": {
          "$ref": "#/$defs/sha1"
        }
      }
    }
  }
}
