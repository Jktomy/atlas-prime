{
  "$id": "https://atlas-prime.local/schemas/spear/spear-execution-preview-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "authority": {
      "additionalProperties": false,
      "properties": {
        "cutover_authorized": {
          "const": false
        },
        "deletion_authorized": {
          "const": false
        },
        "draft_pr_only": {
          "const": true
        },
        "merge_authorized": {
          "const": false
        },
        "migration_authorized": {
          "const": false
        },
        "promotion_authorized": {
          "const": false
        }
      },
      "required": [
        "draft_pr_only",
        "merge_authorized",
        "deletion_authorized",
        "migration_authorized",
        "promotion_authorized",
        "cutover_authorized"
      ],
      "type": "object"
    },
    "base_branch": {
      "const": "main"
    },
    "base_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "canonical_packet_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "changed_files": {
      "items": {
        "maxLength": 500,
        "minLength": 1,
        "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$",
        "type": "string"
      },
      "maxItems": 5,
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "commit_message": {
      "maxLength": 200,
      "minLength": 1,
      "type": "string"
    },
    "contract_identities": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "git_blob_sha": {
            "pattern": "^[0-9a-f]{40}$",
            "type": "string"
          },
          "path": {
            "maxLength": 500,
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$",
            "type": "string"
          },
          "repository_commit": {
            "pattern": "^[0-9a-f]{40}$",
            "type": "string"
          },
          "sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          }
        },
        "required": [
          "path",
          "repository_commit",
          "git_blob_sha",
          "sha256"
        ],
        "type": "object"
      },
      "maxItems": 20,
      "minItems": 1,
      "type": "array"
    },
    "derived_branch": {
      "pattern": "^spear/[0-9]{8}-[0-9]{3}-[a-f0-9]{8}$",
      "type": "string"
    },
    "draft_pr_body_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "draft_pr_title": {
      "maxLength": 200,
      "minLength": 1,
      "type": "string"
    },
    "manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "operations": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "enum": [
              "CREATE_FILE",
              "REPLACE_FILE_FULL"
            ]
          },
          "new_content_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "old_blob_sha": {
            "oneOf": [
              {
                "pattern": "^[0-9a-f]{40}$",
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          },
          "path": {
            "maxLength": 500,
            "minLength": 1,
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$",
            "type": "string"
          }
        },
        "required": [
          "action",
          "path",
          "old_blob_sha",
          "new_content_sha256"
        ],
        "type": "object"
      },
      "maxItems": 5,
      "minItems": 1,
      "type": "array"
    },
    "packet_id": {
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
      "type": "string"
    },
    "packet_transport_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "preview_version": {
      "const": "1.0"
    },
    "protected_boundary": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNINGS"
      ]
    },
    "repository": {
      "const": "Jktomy/atlas-prime"
    },
    "rollback_posture": {
      "enum": [
        "ISOLATED_REVERT_PLANNED",
        "REPLACEMENT_PR_REQUIRED"
      ]
    }
  },
  "required": [
    "preview_version",
    "repository",
    "base_branch",
    "base_commit",
    "packet_id",
    "packet_transport_sha256",
    "canonical_packet_sha256",
    "manifest_sha256",
    "changed_files",
    "operations",
    "derived_branch",
    "commit_message",
    "draft_pr_title",
    "draft_pr_body_sha256",
    "contract_identities",
    "protected_boundary",
    "rollback_posture",
    "authority"
  ],
  "title": "Athena's Spear S1 Approved Preview v1",
  "type": "object"
}
