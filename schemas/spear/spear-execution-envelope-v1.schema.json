{
  "$id": "https://atlas-prime.local/schemas/spear/spear-execution-envelope-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approval": {
      "additionalProperties": false,
      "properties": {
        "approved_scope": {
          "const": "CREATE_DRAFT_PR_ONLY"
        },
        "reference": {
          "maxLength": 1000,
          "minLength": 1,
          "type": "string"
        },
        "source": {
          "const": "APPROVED_PREVIEW_EXECUTE"
        }
      },
      "required": [
        "source",
        "reference",
        "approved_scope"
      ],
      "type": "object"
    },
    "approved_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "approved_preview_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "authority": {
      "additionalProperties": false,
      "properties": {
        "cutover_authorized": {
          "const": false
        },
        "deletion_authorized": {
          "const": false
        },
        "draft_pr_only": {
          "const": true
        },
        "merge_authorized": {
          "const": false
        },
        "migration_authorized": {
          "const": false
        },
        "promotion_authorized": {
          "const": false
        }
      },
      "required": [
        "draft_pr_only",
        "merge_authorized",
        "deletion_authorized",
        "migration_authorized",
        "promotion_authorized",
        "cutover_authorized"
      ],
      "type": "object"
    },
    "confirmation": {
      "const": "EXECUTE_APPROVED_PREVIEW_ONLY"
    },
    "envelope_version": {
      "const": "1.0"
    },
    "execution_mode": {
      "const": "CREATE_DRAFT_PR_ONLY"
    },
    "expected_base_commit": {
      "pattern": "^[0-9a-f]{40}$",
      "type": "string"
    },
    "packet_b64": {
      "maxLength": 65536,
      "minLength": 4,
      "pattern": "^[A-Za-z0-9+/]*={0,2}$",
      "type": "string"
    },
    "packet_id": {
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$",
      "type": "string"
    },
    "packet_transport_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "plan_created_at": {
      "format": "date-time",
      "type": "string"
    },
    "plan_expires_at": {
      "format": "date-time",
      "type": "string"
    },
    "preview_b64": {
      "maxLength": 65536,
      "minLength": 4,
      "pattern": "^[A-Za-z0-9+/]*={0,2}$",
      "type": "string"
    }
  },
  "required": [
    "envelope_version",
    "packet_id",
    "packet_b64",
    "packet_transport_sha256",
    "preview_b64",
    "approved_preview_sha256",
    "approved_manifest_sha256",
    "expected_base_commit",
    "approval",
    "execution_mode",
    "plan_created_at",
    "plan_expires_at",
    "confirmation",
    "authority"
  ],
  "title": "Athena's Spear S1 Execution Envelope v1",
  "type": "object"
}
