{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/quest-board-v1.schema.json",
  "title": "Frozen Prime Quest Board predecessor evidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "canonical_repository",
    "entries",
    "format_version",
    "generated",
    "predecessor_workboard_route",
    "state",
    "frozen_by_mission",
    "frozen_by_issue",
    "frozen_from_main",
    "successor_registry",
    "registry_role"
  ],
  "properties": {
    "canonical_repository": {"const": "Jktomy/atlas-prime"},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["next_gate", "owner", "quest_id", "source", "state"],
        "allOf": [
          {
            "if": {"properties": {"state": {"const": "COMPLETE"}}},
            "then": {"required": ["completion_basis"], "properties": {"next_gate": {"const": "CLOSED"}}}
          }
        ],
        "properties": {
          "completion_basis": {"type": "string", "minLength": 1, "maxLength": 500},
          "next_gate": {"type": "string", "minLength": 1, "maxLength": 300},
          "owner": {"type": "string", "minLength": 1, "maxLength": 160},
          "quest_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
          "readiness_basis": {"type": "string", "minLength": 1, "maxLength": 500},
          "source": {"type": "string", "pattern": "^quests/[a-z0-9][a-z0-9-]*\\.md$"},
          "state": {"enum": ["READY_FOR_CAMPAIGN_1_PREVIEW", "READY_FOR_JAYSON_EXECUTION_PACKAGE", "IN_PROGRESS", "BLOCKED", "COMPLETE"]}
        }
      }
    },
    "format_version": {"const": "1.0"},
    "generated": {"const": false},
    "predecessor_workboard_route": {"const": "HISTORICAL_ONLY"},
    "state": {"const": "CANONICAL_ACTIVE"},
    "frozen_by_mission": {"const": "MISSION-QUEST-REGISTRY-MISSION-BOARD-CUTOVER-R01"},
    "frozen_by_issue": {"const": 278},
    "frozen_from_main": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "successor_registry": {"const": "continuity/mission-board-quest-registry-r01.json"},
    "registry_role": {"const": "FROZEN_PREDECESSOR_EVIDENCE"}
  }
}
