{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas-prime://schemas/quest-board-v1.schema.json",
  "title": "Atlas Prime Quest Board v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority_state",
    "quests"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "authority_state": {
      "enum": [
        "SHADOW",
        "CANONICAL",
        "HISTORICAL"
      ]
    },
    "source_workboard": {
      "type": [
        "object",
        "null"
      ]
    },
    "quests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "quest_id",
          "title",
          "owner_project",
          "owner_operation",
          "status",
          "desired_end_state",
          "emberline",
          "campaigns",
          "completion_range",
          "confidence",
          "next_safe_action",
          "next_approval_gate",
          "last_verified"
        ],
        "properties": {
          "quest_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9._-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "owner_project": {
            "type": "string",
            "minLength": 1
          },
          "owner_operation": {
            "type": "string",
            "minLength": 1
          },
          "supporting_projects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "enum": [
              "ACTIVE",
              "BLOCKED",
              "WAITING",
              "PARKED",
              "CLOSEOUT_READY",
              "COMPLETE"
            ]
          },
          "desired_end_state": {
            "type": "string",
            "minLength": 1
          },
          "emberline": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "current_campaign_id",
              "current_gate",
              "completed_durable_work",
              "chat_only_or_uncertain",
              "remaining_work",
              "protected_boundary_posture",
              "next_safe_action",
              "next_approval_gate",
              "restart_safe",
              "solar_eclipse_ready",
              "sunset_ready",
              "must_not_happen_yet"
            ],
            "properties": {
              "current_campaign_id": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "current_gate": {
                "type": "string"
              },
              "completed_durable_work": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "chat_only_or_uncertain": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "remaining_work": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "protected_boundary_posture": {
                "type": "string"
              },
              "next_safe_action": {
                "type": "string"
              },
              "next_approval_gate": {
                "type": "string"
              },
              "restart_safe": {
                "type": "boolean"
              },
              "solar_eclipse_ready": {
                "type": "boolean"
              },
              "sunset_ready": {
                "type": "boolean"
              },
              "must_not_happen_yet": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "campaigns": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "campaign_id",
                "parent_quest_id",
                "title",
                "status",
                "required_for_quest_completion",
                "current_gate",
                "next_safe_action",
                "last_verified"
              ],
              "properties": {
                "campaign_id": {
                  "type": "string"
                },
                "parent_quest_id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "status": {
                  "enum": [
                    "ACTIVE",
                    "BLOCKED",
                    "WAITING",
                    "PARKED",
                    "COMPLETE",
                    "ABANDONED"
                  ]
                },
                "required_for_quest_completion": {
                  "type": "boolean"
                },
                "current_gate": {
                  "type": "string"
                },
                "completion_range": {
                  "type": "object",
                  "required": [
                    "min",
                    "max"
                  ],
                  "properties": {
                    "min": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 100
                    },
                    "max": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 100
                    }
                  }
                },
                "confidence": {
                  "enum": [
                    "LOW",
                    "MEDIUM",
                    "HIGH"
                  ]
                },
                "dependencies": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "blockers": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "next_safe_action": {
                  "type": "string"
                },
                "last_verified": {
                  "type": "string",
                  "format": "date"
                }
              }
            }
          },
          "completion_range": {
            "type": "object",
            "required": [
              "min",
              "max",
              "basis"
            ],
            "properties": {
              "min": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "max": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "basis": {
                "type": "string"
              }
            }
          },
          "confidence": {
            "enum": [
              "LOW",
              "MEDIUM",
              "HIGH"
            ]
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "next_safe_action": {
            "type": "string"
          },
          "next_approval_gate": {
            "type": "string"
          },
          "last_verified": {
            "type": "string",
            "format": "date"
          }
        }
      }
    }
  }
}
