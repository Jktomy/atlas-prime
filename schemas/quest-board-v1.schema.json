{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/quest-board-v1.schema.json",
  "title": "Prime Quest Board v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["canonical_repository", "entries", "format_version", "generated", "predecessor_workboard_route", "state"],
  "properties": {
    "canonical_repository": {"const": "Jktomy/atlas-prime"},
    "entries": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["next_gate", "owner", "quest_id", "source", "state"], "properties": {
      "completion_basis": {"type": "string", "minLength": 1, "maxLength": 500},
      "next_gate": {"type": "string", "minLength": 1, "maxLength": 300},
      "owner": {"type": "string", "minLength": 1, "maxLength": 160},
      "quest_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
      "readiness_basis": {"type": "string", "minLength": 1, "maxLength": 500},
      "source": {"type": "string", "pattern": "^quests/[a-z0-9][a-z0-9-]*\\.md$"},
      "state": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,79}$"}
    }}},
    "format_version": {"const": "1.0"},
    "generated": {"const": false},
    "predecessor_workboard_route": {"const": "HISTORICAL_ONLY"},
    "state": {"const": "CANONICAL_ACTIVE"}
  }
}
