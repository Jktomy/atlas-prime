{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/shardblade-campaign-stage-receipt-v1.schema.json",
  "title": "Prime Campaign Shardblade stage action receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "attempt_id", "nonce", "request_id", "request_sha256", "campaign_id", "stage_id", "action", "executed_at", "result", "error_code", "repository", "pull_request", "base_sha", "head_sha", "tree_sha", "observed_pr_state", "merge_commit_sha", "canonical_main_sha", "canonical_tree_sha", "candidate_unchanged", "rollback", "warrant_status"],
  "properties": {
    "schema_version": {"const": "atlas.shardblade-campaign-stage-receipt.v1"},
    "receipt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "attempt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9._-]{16,160}$"},
    "request_id": {"type": "string", "minLength": 3},
    "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "campaign_id": {"type": "string", "minLength": 3},
    "stage_id": {"type": "integer", "minimum": 0},
    "action": {"enum": ["READY", "MERGE"]},
    "executed_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "result": {"enum": ["SUCCESS", "REJECTED", "BLOCKED", "PARTIAL"]},
    "error_code": {"type": ["string", "null"], "maxLength": 120},
    "repository": {"const": "Jktomy/atlas-prime"},
    "pull_request": {"type": "integer", "minimum": 1},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "observed_pr_state": {"enum": ["DRAFT", "OPEN_READY", "MERGED", "UNKNOWN"]},
    "merge_commit_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "canonical_main_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "canonical_tree_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "candidate_unchanged": {"const": true},
    "rollback": {"enum": ["CLOSE_PR_BEFORE_MERGE", "REVIEWED_REVERT_PR", "NO_MUTATION", "PRESERVE_AND_READBACK_ONLY"]},
    "warrant_status": {"enum": ["ACTIVE", "COMPLETED", "STOPPED", "REVOKED", "REPLACED"]}
  }
}
