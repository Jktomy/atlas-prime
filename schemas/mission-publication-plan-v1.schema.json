{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/mission-publication-plan-v1.schema.json",
  "title": "Atlas Mission Publication Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version","repository","issue_number","mission_id","attempt_id","canonical_base","branch","commit_message","pull_request_title","changed_paths","changed_paths_digest","objective_digest","publisher","public_clean","next_safe_action"],
  "properties": {
    "schema_version": {"const": "atlas.mission-publication-plan.v1"},
    "repository": {"type":"string","pattern":"^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "issue_number": {"type":"integer","minimum":1},
    "mission_id": {"type":"string","minLength":3},
    "attempt_id": {"type":"string","minLength":3},
    "canonical_base": {"type":"string","pattern":"^[0-9a-f]{40}$"},
    "branch": {"type":"string","pattern":"^mission/[a-z0-9][a-z0-9-]{1,80}$"},
    "commit_message": {"type":"string","minLength":3},
    "pull_request_title": {"type":"string","minLength":3},
    "changed_paths": {"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string","pattern":"^(?!/)(?![A-Za-z]:/)(?!.*(?:^|/)\.\.(?:/|$))(?!.*\\\\).+$"}},
    "changed_paths_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "objective_digest": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "publisher": {"enum":["MISSION_BOARD_ADAPTER","INDEPENDENT_RECOVERY_ADAPTER"]},
    "public_clean": {"const":true},
    "next_safe_action": {"type":"string","minLength":3}
  }
}
