{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jktomy/atlas-prime/schemas/quest-sync-receipt-v1.schema.json",
  "title": "Atlas Quest synchronization receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "receipt_id",
    "repository",
    "child_mission_id",
    "child_issue_number",
    "merged_commit",
    "changed_paths_digest",
    "parent_quest_id",
    "parent_issue_number",
    "parent_mission_id",
    "impact_summary",
    "readback_status"
  ],
  "properties": {
    "schema_id": { "const": "atlas.mission.quest-sync-receipt" },
    "schema_version": { "const": "1.0.0" },
    "receipt_id": { "type": "string", "pattern": "^QSR-[A-Z2-7]{26}$" },
    "repository": { "const": "Jktomy/atlas-prime" },
    "child_mission_id": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$" },
    "child_issue_number": { "type": "integer", "minimum": 1 },
    "merged_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "changed_paths_digest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "parent_quest_id": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$" },
    "parent_issue_number": { "type": "integer", "minimum": 1 },
    "parent_mission_id": { "type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$" },
    "impact_summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "readback_status": { "const": "EXACT_MERGED_MAIN" }
  }
}
