{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/shardblade-campaign-warrant-v1.schema.json",
  "title": "Prime bounded Campaign Shardblade warrant v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "campaign_id", "gemstone_id", "authorization_receipt_sha256", "authorizer", "repository", "issued_at", "expires_at", "status", "stages", "stop_conditions", "forbidden", "completion_stage_id", "no_standing_authority"],
  "properties": {
    "schema_version": {"const": "atlas.shardblade-campaign-warrant.v1"},
    "campaign_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "gemstone_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "authorization_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "authorizer": {"const": "Jayson"},
    "repository": {"const": "Jktomy/atlas-prime"},
    "issued_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "expires_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "status": {"enum": ["ACTIVE", "COMPLETED", "STOPPED", "REVOKED", "REPLACED"]},
    "stages": {"type": "array", "minItems": 1, "maxItems": 64, "items": {"type": "object", "additionalProperties": false, "required": ["stage_id", "route", "base_source", "initial_base_sha", "allowed_paths", "actions"], "properties": {
      "stage_id": {"type": "integer", "minimum": 0},
      "route": {"enum": ["AEGIS_BREAK_BOOTSTRAP", "CAMPAIGN_SHARDBLADE"]},
      "base_source": {"enum": ["EXACT_INITIAL", "PRIOR_STAGE_MERGE"]},
      "initial_base_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
      "allowed_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
      "actions": {"const": ["READY", "MERGE"]}
    }}},
    "stop_conditions": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 120}},
    "forbidden": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 120}},
    "completion_stage_id": {"type": "integer", "minimum": 0},
    "no_standing_authority": {"const": true}
  }
}
