{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/investiture-operation-receipt-v1.schema.json",
  "title": "Found Silverlight sanitized operation receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "result", "error_code", "ledger_id", "generation_id", "event_id", "replay_identity_sha256", "input_sha256", "input_byte_count", "sequence", "record_sha256", "head_sha256", "ledger_mutation_performed", "receipt_sha256"],
  "properties": {
    "schema_version": {"const": "atlas.investiture-operation-receipt.v1"},
    "result": {"enum": ["COMMITTED", "ALREADY_COMMITTED", "QUARANTINED"]},
    "error_code": {"type": ["string", "null"], "pattern": "^[A-Z][A-Z0-9_]{0,79}$"},
    "ledger_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+){2,15}$"},
    "generation_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+){2,15}$"},
    "event_id": {"type": ["string", "null"], "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+){2,15}$"},
    "replay_identity_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "input_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "input_byte_count": {"type": "integer", "minimum": 0},
    "sequence": {"type": ["integer", "null"], "minimum": 1},
    "record_sha256": {"type": ["string", "null"], "pattern": "^[a-f0-9]{64}$"},
    "head_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "ledger_mutation_performed": {"type": "boolean"},
    "receipt_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
