{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/prime-continuity-register-v1.schema.json",
  "title": "Prime unfinished-work continuity register v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "authority", "register_id", "register_revision", "source_base_sha", "quest_board_sha256", "event_ids", "entries"],
  "properties": {
    "schema_version": {"const": "atlas.prime-continuity-register.v1"},
    "authority": {"const": "CANONICAL_OPERATIONAL_CONTINUITY"},
    "register_id": {"const": "PRIME-CONTINUITY-R01"},
    "register_revision": {"type": "integer", "minimum": 1},
    "source_base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "quest_board_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "event_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"}},
    "entries": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["continuity_id", "quest_id", "quest_source", "quest_source_sha256", "quest_state", "campaign_id", "mission_id", "gate_id", "current_position", "blockers", "next_action", "next_approval", "revision", "last_event_id"], "properties": {
      "continuity_id": {"type": "string", "pattern": "^CONT-[A-Z0-9-]{3,120}$"},
      "quest_id": {"type": "string", "minLength": 1, "maxLength": 128},
      "quest_source": {"type": "string", "pattern": "^quests/[a-z0-9][a-z0-9-]*\\.md$"},
      "quest_source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
      "quest_state": {"type": "string", "minLength": 1, "maxLength": 80},
      "campaign_id": {"type": ["string", "null"], "maxLength": 128},
      "mission_id": {"type": ["string", "null"], "maxLength": 128},
      "gate_id": {"type": "string", "minLength": 1, "maxLength": 160},
      "current_position": {"type": "string", "minLength": 1, "maxLength": 500},
      "blockers": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 300}},
      "next_action": {"type": "string", "minLength": 1, "maxLength": 500},
      "next_approval": {"type": "string", "minLength": 1, "maxLength": 300},
      "revision": {"type": "integer", "minimum": 1},
      "last_event_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"}
    }} }
  }
}
