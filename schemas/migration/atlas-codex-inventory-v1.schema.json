{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-prime.local/schemas/atlas-codex-inventory-v1.schema.json",
  "title": "Atlas Codex to Atlas Prime Migration Inventory v1",
  "description": "Zero-silent-loss inventory and disposition ledger for every tracked atlas-codex path.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "migration_id",
    "source_repository",
    "source_commit",
    "target_repository",
    "target_format_version",
    "created_at",
    "prepared_by",
    "status",
    "entries",
    "inventory_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "migration_id": {
      "type": "string",
      "pattern": "^atlas-codex-to-prime:[a-z0-9][a-z0-9-]{2,63}$"
    },
    "source_repository": {
      "const": "Jktomy/atlas-codex"
    },
    "source_commit": {
      "$ref": "#/$defs/git_object_id"
    },
    "target_repository": {
      "const": "Jktomy/atlas-prime"
    },
    "target_format_version": {
      "const": "1.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "prepared_by": {
      "enum": [
        "ATHENA",
        "JAYSON",
        "MIGRATION_TOOL"
      ]
    },
    "status": {
      "enum": [
        "DRAFT",
        "INVENTORY_COMPLETE",
        "MAPPING_COMPLETE",
        "IN_PROGRESS",
        "CUTOVER_READY",
        "CLOSED"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      },
      "minItems": 1,
      "maxItems": 20000
    },
    "inventory_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$"
    },
    "git_object_id": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "sha1",
            "sha256"
          ]
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "algorithm": {
                "const": "sha1"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^[0-9a-f]{40}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "algorithm": {
                "const": "sha256"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        }
      ]
    },
    "approval_basis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "reference",
        "approved_scope"
      ],
      "properties": {
        "source": {
          "enum": [
            "EXPLICIT_JAYSON_INSTRUCTION",
            "APPROVED_PREVIEW_EXECUTE",
            "CUTOVER_APPROVAL",
            "RETIREMENT_APPROVAL"
          ]
        },
        "reference": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000
        },
        "approved_scope": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "approved_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_path",
        "source_git_blob",
        "source_sha256",
        "source_class",
        "privacy_class",
        "disposition",
        "content_transfer",
        "target_paths",
        "preserved_elements",
        "removed_or_remodeled_elements",
        "reason",
        "dependencies",
        "replacement_routing",
        "private_pointer",
        "omission_reason",
        "approval_basis",
        "packet_id",
        "pr_number",
        "merge_commit",
        "noctua_outcome",
        "noctua_receipt",
        "final_state",
        "notes"
      ],
      "properties": {
        "source_path": {
          "$ref": "#/$defs/path"
        },
        "source_git_blob": {
          "$ref": "#/$defs/git_object_id"
        },
        "source_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source_class": {
          "enum": [
            "BOOTSTRAP",
            "CANONICAL_SOURCE",
            "PROTOCOL",
            "STANDARD",
            "PROJECT",
            "OPERATION",
            "RUNBOOK",
            "REGISTER",
            "GENERATED",
            "ARCHIVE",
            "MIGRATION",
            "TOOL",
            "WORKFLOW",
            "TEST",
            "OTHER"
          ]
        },
        "privacy_class": {
          "enum": [
            "PUBLIC_CLEAN",
            "PRIVATE_CLEAN_SUMMARY",
            "POINTER_ONLY",
            "PROHIBITED"
          ]
        },
        "disposition": {
          "enum": [
            "MIGRATE",
            "MERGE",
            "REMODEL",
            "GENERATED_REBUILD",
            "HISTORICAL_REFERENCE",
            "PRIVATE_POINTER",
            "SUPERSEDE",
            "RETIRE",
            "OMIT_WITH_REASON"
          ]
        },
        "content_transfer": {
          "enum": [
            "FULL",
            "PARTIAL",
            "NONE",
            "POINTER_ONLY",
            "GENERATED_REBUILD"
          ]
        },
        "target_paths": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          },
          "uniqueItems": true,
          "maxItems": 50
        },
        "preserved_elements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "uniqueItems": true,
          "maxItems": 200
        },
        "removed_or_remodeled_elements": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1000
          },
          "uniqueItems": true,
          "maxItems": 200
        },
        "reason": {
          "type": "string",
          "minLength": 10,
          "maxLength": 4000
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          },
          "uniqueItems": true,
          "maxItems": 200
        },
        "replacement_routing": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 5,
              "maxLength": 2000
            },
            {
              "type": "null"
            }
          ]
        },
        "private_pointer": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "system",
                "clean_pointer",
                "contains_no_raw_protected_evidence"
              ],
              "properties": {
                "system": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 100
                },
                "clean_pointer": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 1000
                },
                "contains_no_raw_protected_evidence": {
                  "const": true
                }
              }
            },
            {
              "type": "null"
            }
          ]
        },
        "omission_reason": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 10,
              "maxLength": 2000
            },
            {
              "type": "null"
            }
          ]
        },
        "approval_basis": {
          "oneOf": [
            {
              "$ref": "#/$defs/approval_basis"
            },
            {
              "type": "null"
            }
          ]
        },
        "packet_id": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 8,
              "maxLength": 200
            },
            {
              "type": "null"
            }
          ]
        },
        "pr_number": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "merge_commit": {
          "oneOf": [
            {
              "$ref": "#/$defs/git_object_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "noctua_outcome": {
          "oneOf": [
            {
              "enum": [
                "YES",
                "NO",
                "NEEDS_JAYSON",
                "BLOCKED",
                "CAPTURE_ONLY"
              ]
            },
            {
              "type": "null"
            }
          ]
        },
        "noctua_receipt": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 1000
            },
            {
              "type": "null"
            }
          ]
        },
        "final_state": {
          "enum": [
            "INVENTORIED",
            "MAPPED",
            "PACKET_PLANNED",
            "STAGED",
            "MERGED",
            "READBACK_VERIFIED",
            "ABSORBED",
            "DEFERRED",
            "BLOCKED",
            "RETIRED",
            "OMITTED"
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 4000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "disposition": {
                "enum": [
                  "MIGRATE",
                  "MERGE",
                  "REMODEL",
                  "GENERATED_REBUILD",
                  "PRIVATE_POINTER",
                  "SUPERSEDE",
                  "HISTORICAL_REFERENCE"
                ]
              }
            }
          },
          "then": {
            "properties": {
              "target_paths": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "disposition": {
                "const": "OMIT_WITH_REASON"
              }
            }
          },
          "then": {
            "required": [
              "omission_reason",
              "approval_basis"
            ],
            "properties": {
              "omission_reason": {
                "type": "string",
                "minLength": 10
              },
              "approval_basis": {
                "$ref": "#/$defs/approval_basis"
              },
              "final_state": {
                "enum": [
                  "DEFERRED",
                  "BLOCKED",
                  "OMITTED"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "disposition": {
                "const": "PRIVATE_POINTER"
              }
            }
          },
          "then": {
            "properties": {
              "content_transfer": {
                "const": "POINTER_ONLY"
              },
              "private_pointer": {
                "type": "object",
                "required": [
                  "system",
                  "clean_pointer",
                  "contains_no_raw_protected_evidence"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "disposition": {
                "const": "RETIRE"
              }
            }
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "replacement_routing": {
                    "type": "string",
                    "minLength": 5
                  }
                }
              },
              {
                "properties": {
                  "omission_reason": {
                    "type": "string",
                    "minLength": 10
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "privacy_class": {
                "const": "PROHIBITED"
              }
            }
          },
          "then": {
            "properties": {
              "disposition": {
                "enum": [
                  "PRIVATE_POINTER",
                  "OMIT_WITH_REASON"
                ]
              },
              "content_transfer": {
                "enum": [
                  "POINTER_ONLY",
                  "NONE"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "final_state": {
                "const": "ABSORBED"
              }
            }
          },
          "then": {
            "properties": {
              "packet_id": {
                "type": "string",
                "minLength": 8
              },
              "pr_number": {
                "type": "integer",
                "minimum": 1
              },
              "merge_commit": {
                "$ref": "#/$defs/git_object_id"
              },
              "noctua_outcome": {
                "const": "YES"
              },
              "noctua_receipt": {
                "type": "string",
                "minLength": 1
              },
              "approval_basis": {
                "$ref": "#/$defs/approval_basis"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "final_state": {
                "const": "RETIRED"
              }
            }
          },
          "then": {
            "properties": {
              "approval_basis": {
                "$ref": "#/$defs/approval_basis"
              },
              "disposition": {
                "const": "RETIRE"
              }
            }
          }
        }
      ]
    }
  }
}
