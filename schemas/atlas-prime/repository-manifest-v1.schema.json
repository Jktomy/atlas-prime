{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-prime.local/schemas/repository-manifest-v1.schema.json",
  "title": "Atlas Prime Repository Manifest v1",
  "description": "Generated verification manifest for present and planned Atlas Prime repository paths.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "repository",
    "repository_state",
    "canonical_predecessor",
    "base_commit",
    "generated_at",
    "generator",
    "contracts",
    "entries",
    "manifest_sha256"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^atlas-prime-manifest:[0-9]{4}-[0-9]{2}-[0-9]{2}:[a-z0-9][a-z0-9-]{2,63}$"
    },
    "repository": {
      "const": "Jktomy/atlas-prime"
    },
    "repository_state": {
      "enum": [
        "SHADOW",
        "CUTOVER_CANDIDATE",
        "CANONICAL",
        "FROZEN",
        "RETIRED"
      ]
    },
    "canonical_predecessor": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        {
          "type": "null"
        }
      ]
    },
    "base_commit": {
      "$ref": "#/$defs/git_object_id"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "contract_path"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "contract_path": {
          "$ref": "#/$defs/path"
        }
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository_format",
        "source_metadata",
        "migration_inventory",
        "destination_policy",
        "protected_paths_policy"
      ],
      "properties": {
        "repository_format": {
          "$ref": "#/$defs/contract_ref"
        },
        "source_metadata": {
          "$ref": "#/$defs/contract_ref"
        },
        "migration_inventory": {
          "$ref": "#/$defs/contract_ref"
        },
        "destination_policy": {
          "$ref": "#/$defs/contract_ref"
        },
        "protected_paths_policy": {
          "$ref": "#/$defs/contract_ref"
        }
      }
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      },
      "maxItems": 10000,
      "minItems": 1
    },
    "manifest_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$"
    },
    "git_object_id": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "enum": [
            "sha1",
            "sha256"
          ]
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$|^[0-9a-f]{64}$"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "algorithm": {
                "const": "sha1"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^[0-9a-f]{40}$"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "algorithm": {
                "const": "sha256"
              }
            }
          },
          "then": {
            "properties": {
              "value": {
                "pattern": "^[0-9a-f]{64}$"
              }
            }
          }
        }
      ]
    },
    "contract_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "lifecycle",
        "present",
        "authority_class",
        "source_type",
        "owner_project",
        "owner_operation",
        "protected_level",
        "write_lane",
        "mutable_by",
        "schema_or_contract",
        "routing_hooks",
        "dependencies",
        "cutover_required",
        "notes"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/path"
        },
        "lifecycle": {
          "enum": [
            "REQUIRED_NOW",
            "PLANNED",
            "CONDITIONAL",
            "GENERATED",
            "MIGRATION_ONLY",
            "RETIRED"
          ]
        },
        "present": {
          "type": "boolean"
        },
        "authority_class": {
          "enum": [
            "CANONICAL_AUTHORED_SOURCE",
            "STRUCTURED_AUTHORITATIVE_REGISTER",
            "GENERATED_OPERATIONAL_PROJECTION",
            "CONTINUITY_PROVENANCE",
            "TOOL_CONTRACT",
            "TOOL_IMPLEMENTATION",
            "MIGRATION_EVIDENCE",
            "HISTORICAL_REFERENCE",
            "PRIVATE_POINTER"
          ]
        },
        "source_type": {
          "enum": [
            "BOOTSTRAP",
            "CORE_DOCTRINE",
            "PROTOCOL",
            "STANDARD",
            "SPECIFICATION",
            "POLICY",
            "PROJECT",
            "OPERATION",
            "RUNBOOK",
            "TEMPLATE",
            "REFERENCE",
            "REGISTER_VIEW",
            "GENERATED_VIEW",
            "MIGRATION_RECORD",
            "HISTORICAL_RECORD",
            "TOOL_DOCUMENTATION",
            "SCHEMA",
            "STRUCTURED_REGISTER",
            "EVENT_LEDGER",
            "SOURCE_CODE",
            "TEST",
            "WORKFLOW",
            "CONFIGURATION"
          ]
        },
        "owner_project": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "owner_operation": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            {
              "type": "null"
            }
          ]
        },
        "protected_level": {
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "CRITICAL"
          ]
        },
        "write_lane": {
          "enum": [
            "SOURCE_PR",
            "GENERATED_PR",
            "ATOMIC_OPERATIONAL_PROJECTION",
            "MIGRATION_PR",
            "MANUAL_BOOTSTRAP_ONLY",
            "NEVER"
          ]
        },
        "mutable_by": {
          "type": "array",
          "items": {
            "enum": [
              "JAYSON",
              "ATHENA_PREVIEW",
              "SPEAR",
              "PHOENIX_TOOL",
              "GENERATOR",
              "MIGRATION_TOOL",
              "NO_ONE"
            ]
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "schema_or_contract": {
          "oneOf": [
            {
              "$ref": "#/$defs/path"
            },
            {
              "type": "null"
            }
          ]
        },
        "routing_hooks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          },
          "uniqueItems": true,
          "maxItems": 100
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          },
          "uniqueItems": true,
          "maxItems": 100
        },
        "git_blob": {
          "oneOf": [
            {
              "$ref": "#/$defs/git_object_id"
            },
            {
              "type": "null"
            }
          ]
        },
        "sha256": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            },
            {
              "type": "null"
            }
          ]
        },
        "cutover_required": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "present": {
                "const": true
              }
            }
          },
          "then": {
            "required": [
              "git_blob",
              "sha256"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "lifecycle": {
                "const": "GENERATED"
              }
            }
          },
          "then": {
            "properties": {
              "authority_class": {
                "const": "GENERATED_OPERATIONAL_PROJECTION"
              },
              "write_lane": {
                "enum": [
                  "GENERATED_PR",
                  "ATOMIC_OPERATIONAL_PROJECTION"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "write_lane": {
                "const": "NEVER"
              }
            }
          },
          "then": {
            "properties": {
              "mutable_by": {
                "contains": {
                  "const": "NO_ONE"
                }
              }
            }
          }
        }
      ]
    }
  }
}
