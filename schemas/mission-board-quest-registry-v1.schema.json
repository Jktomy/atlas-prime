{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/mission-board-quest-registry-v1.schema.json",
  "title": "Mission Board admitted Quest registry recovery snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "authority",
    "repository",
    "registry_id",
    "registry_revision",
    "state",
    "platform",
    "live_issue_availability_required_for_recovery",
    "cutover",
    "entries"
  ],
  "properties": {
    "schema_version": {"const": "atlas.mission-board-quest-registry.v1"},
    "authority": {"const": "CANONICAL_ADMITTED_QUEST_REGISTRY"},
    "repository": {"const": "Jktomy/atlas-prime"},
    "registry_id": {"const": "MISSION-BOARD-QUEST-REGISTRY-R01"},
    "registry_revision": {"type": "integer", "minimum": 1},
    "state": {"const": "CANONICAL_ACTIVE"},
    "platform": {"const": "GitHub Issues"},
    "live_issue_availability_required_for_recovery": {"const": false},
    "cutover": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mission_id",
        "issue_number",
        "canonical_base",
        "predecessor_path",
        "predecessor_sha256",
        "predecessor_state",
        "baseline_active_quest_ids",
        "baseline_completed_quest_count"
      ],
      "properties": {
        "mission_id": {"const": "MISSION-QUEST-REGISTRY-MISSION-BOARD-CUTOVER-R01"},
        "issue_number": {"const": 278},
        "canonical_base": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "predecessor_path": {"const": "quest-board/quest-board-v1.json"},
        "predecessor_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "predecessor_state": {"const": "FROZEN_PREDECESSOR_EVIDENCE"},
        "baseline_active_quest_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"}
        },
        "baseline_completed_quest_count": {"type": "integer", "minimum": 0}
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "next_gate",
          "owner",
          "quest_id",
          "readiness_basis",
          "source",
          "state",
          "parent_issue_number",
          "parent_mission_id",
          "parent_attempt_id",
          "parent_mission_state",
          "parent_source_status"
        ],
        "properties": {
          "next_gate": {"type": "string", "minLength": 1, "maxLength": 300},
          "owner": {"type": "string", "minLength": 1, "maxLength": 160},
          "quest_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
          "readiness_basis": {"type": "string", "minLength": 1, "maxLength": 500},
          "source": {"type": "string", "pattern": "^quests/[a-z0-9][a-z0-9-]*\\.md$"},
          "state": {"enum": ["READY_FOR_CAMPAIGN_1_PREVIEW", "READY_FOR_JAYSON_EXECUTION_PACKAGE", "IN_PROGRESS", "BLOCKED"]},
          "parent_issue_number": {"type": "integer", "minimum": 1},
          "parent_mission_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
          "parent_attempt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9-]{2,127}$"},
          "parent_mission_state": {"enum": ["CAPTURED", "TRIAGED", "READY", "IN_PROGRESS", "BLOCKED_RESUMABLE", "PR_OPEN", "VALIDATING", "READY_FOR_PERMANENCE"]},
          "parent_source_status": {"enum": ["PHOENIX_PENDING", "NO_SOURCE_CHANGE_REQUIRED", "PR_OPEN", "MERGED_PENDING_READBACK", "CANONICAL"]}
        }
      }
    }
  }
}
