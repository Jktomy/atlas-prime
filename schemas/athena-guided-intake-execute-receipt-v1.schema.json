{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/athena-guided-intake-execute-receipt-v1.schema.json",
  "title": "Athena guided intake execute receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "result", "repository", "preview_sha256", "carrier_sha256", "mission_id", "mission_sha256", "canonical_main_sha", "workflow_ref", "workflow_blob_sha", "launch_nonce_sha256", "dispatch_transport", "workflow_run_id", "workflow_run_url", "workflow_run_head_sha", "stop_point", "rollback", "forbidden_actions"],
  "properties": {
    "schema_version": {"const": "atlas.athena.guided-intake-execute-receipt.v1"},
    "result": {"const": "DISPATCHED"},
    "repository": {"const": "Jktomy/atlas-prime"},
    "preview_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "carrier_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "mission_id": {"type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*$"},
    "mission_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "canonical_main_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "workflow_ref": {"const": "Jktomy/atlas-prime/.github/workflows/athena-bow-hosted.yml@refs/heads/main"},
    "workflow_blob_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "launch_nonce_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "dispatch_transport": {"const": "GH_WORKFLOW_JSON_STDIN"},
    "workflow_run_id": {"type": "integer", "minimum": 1},
    "workflow_run_url": {"type": "string", "pattern": "^https://github[.]com/Jktomy/atlas-prime/actions/runs/[0-9]+$"},
    "workflow_run_head_sha": {"type": "string", "pattern": "^[a-f0-9]{40}$"},
    "stop_point": {"const": "HOSTED_WORKFLOW_DISPATCH_READBACK"},
    "rollback": {"const": "HOSTED_ROUTE_RECEIPT_GOVERNS"},
    "forbidden_actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_invocation", "branch_write", "direct_main", "force_push", "merge", "pr_write", "ready", "repository_settings", "second_writer", "standing_authority"],
      "properties": {
        "adapter_invocation": {"const": false},
        "branch_write": {"const": false},
        "direct_main": {"const": false},
        "force_push": {"const": false},
        "merge": {"const": false},
        "pr_write": {"const": false},
        "ready": {"const": false},
        "repository_settings": {"const": false},
        "second_writer": {"const": false},
        "standing_authority": {"const": false}
      }
    }
  }
}
