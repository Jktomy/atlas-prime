{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/quest-engine-identity-register-v1.schema.json",
  "title": "Prime Quest Engine identity register v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "quest_id", "campaigns", "state_rules"],
  "properties": {
    "schema_version": {"const": "atlas.quest-engine-identity-register.v1"},
    "quest_id": {"const": "QUEST-REPAIRING-PRIME-R01"},
    "campaigns": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"type": "object", "additionalProperties": false, "required": ["campaign_id", "gate_id", "state", "missions"], "properties": {
      "campaign_id": {"type": "string", "pattern": "^RP-C0[1-8]$"}, "gate_id": {"type": "string", "minLength": 1, "maxLength": 120},
      "state": {"enum": ["PENDING", "IN_PROGRESS", "BLOCKED", "COMPLETE"]},
      "missions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["mission_id", "state"], "properties": {
        "mission_id": {"type": "string", "pattern": "^RP-C[0-9]{2}-M[0-9]{2}$"}, "state": {"enum": ["PROVEN", "PARTIAL", "BLOCKED", "UNPROVEN"]}
      }}}
    }}},
    "state_rules": {"type": "object", "additionalProperties": false, "required": ["allowed_campaign_transitions", "gate_requires_all_missions_terminal", "generated_can_advance", "merge_can_self_certify"], "properties": {
      "allowed_campaign_transitions": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"enum": ["PENDING->IN_PROGRESS", "IN_PROGRESS->BLOCKED", "BLOCKED->IN_PROGRESS", "IN_PROGRESS->COMPLETE"]}},
      "gate_requires_all_missions_terminal": {"const": true}, "generated_can_advance": {"const": false}, "merge_can_self_certify": {"const": false}
    }}
  }
}
