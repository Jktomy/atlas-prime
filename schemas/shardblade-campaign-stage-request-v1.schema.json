{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/shardblade-campaign-stage-request-v1.schema.json",
  "title": "Prime Campaign Shardblade stage action request v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "request_id", "nonce", "campaign_id", "campaign_sha256", "stage_id", "action", "created_at", "readback_at", "authorizer", "repository", "base_sha", "pull_request", "pr_state", "source_branch", "head_sha", "tree_sha", "changed_paths", "preview_sha256", "construction_receipt_sha256", "checks", "reviews", "copilot_dispositions", "prior_ready_receipt_sha256", "fresh_ready_readback_sha256", "merge_method", "forbidden_actions"],
  "properties": {
    "schema_version": {"const": "atlas.shardblade-campaign-stage-request.v1"},
    "request_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9._-]{16,160}$"},
    "campaign_id": {"type": "string", "minLength": 3, "maxLength": 128},
    "campaign_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "stage_id": {"type": "integer", "minimum": 0},
    "action": {"enum": ["READY", "MERGE"]},
    "created_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "readback_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "authorizer": {"const": "Jayson"},
    "repository": {"const": "Jktomy/atlas-prime"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "pull_request": {"type": "integer", "minimum": 1},
    "pr_state": {"enum": ["DRAFT", "OPEN_READY"]},
    "source_branch": {"type": "string", "minLength": 1, "maxLength": 240},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tree_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "changed_paths": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
    "preview_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "construction_receipt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "checks": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["name", "head_sha", "conclusion", "run_id"], "properties": {
      "name": {"type": "string", "minLength": 1}, "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "conclusion": {"const": "SUCCESS"}, "run_id": {"type": "integer", "minimum": 1}
    }}},
    "reviews": {"type": "object", "additionalProperties": false, "required": ["noctua", "ares", "athena", "strikeforce"], "properties": {
      "noctua": {"const": "GREEN"}, "ares": {"const": "GREEN"}, "athena": {"const": "RECONCILED"}, "strikeforce": {"const": "GREEN"}
    }},
    "copilot_dispositions": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["id", "classification", "reason"], "properties": {
      "id": {"type": "string", "minLength": 1}, "classification": {"enum": ["ACTIONABLE", "ALREADY_SATISFIED", "NOT_APPLICABLE", "INCORRECT", "OUT_OF_SCOPE", "REQUIRES_JAYSON_DECISION"]}, "reason": {"type": "string", "minLength": 1}
    }}},
    "prior_ready_receipt_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "fresh_ready_readback_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "merge_method": {"enum": ["MERGE_COMMIT", null]},
    "forbidden_actions": {"type": "object", "additionalProperties": false, "required": ["author", "modify", "widen", "retry_ambiguous", "standing_authority"], "properties": {
      "author": {"const": false}, "modify": {"const": false}, "widen": {"const": false}, "retry_ambiguous": {"const": false}, "standing_authority": {"const": false}
    }}
  }
}
