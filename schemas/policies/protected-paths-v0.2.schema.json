{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-prime.local/schemas/policies/protected-paths-v0.2.schema.json",
  "title": "Atlas Prime Protected Paths v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "policy_id",
    "policy_version",
    "status",
    "mode",
    "repository",
    "principles",
    "actors",
    "protected_sets",
    "content_boundaries",
    "globally_denied_operations",
    "separate_approval_required",
    "exceptions"
  ],
  "properties": {
    "policy_id": {
      "const": "atlas-prime-protected-paths"
    },
    "policy_version": {
      "const": "0.2.0"
    },
    "status": {
      "const": "PREVIEW"
    },
    "mode": {
      "const": "DENY_BY_DEFAULT"
    },
    "repository": {
      "const": "Jktomy/atlas-prime"
    },
    "principles": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string",
        "minLength": 5
      },
      "uniqueItems": true
    },
    "actors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ATHENA",
        "SPEAR",
        "NOCTUA",
        "JAYSON"
      ],
      "properties": {
        "ATHENA": {
          "$ref": "#/$defs/actor"
        },
        "SPEAR": {
          "$ref": "#/$defs/actor"
        },
        "NOCTUA": {
          "$ref": "#/$defs/actor"
        },
        "JAYSON": {
          "$ref": "#/$defs/actor"
        }
      }
    },
    "protected_sets": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/protected_set"
      }
    },
    "content_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prohibited_raw_content",
        "permitted_forms",
        "scanner_is_proof_of_absence",
        "diagnostics_must_redact_matches"
      ],
      "properties": {
        "prohibited_raw_content": {
          "type": "array",
          "minItems": 10,
          "uniqueItems": true
        },
        "permitted_forms": {
          "type": "array",
          "contains": {
            "const": "POINTER_ONLY"
          },
          "uniqueItems": true
        },
        "scanner_is_proof_of_absence": {
          "const": false
        },
        "diagnostics_must_redact_matches": {
          "const": true
        }
      }
    },
    "globally_denied_operations": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "DIRECT_MAIN_WRITE"
          }
        },
        {
          "contains": {
            "const": "FORCE_PUSH"
          }
        },
        {
          "contains": {
            "const": "AUTOMATIC_MERGE"
          }
        },
        {
          "contains": {
            "const": "HARD_DELETE"
          }
        },
        {
          "contains": {
            "const": "SPEAR_SELF_MODIFICATION"
          }
        },
        {
          "contains": {
            "const": "SILENT_SOURCE_PROMOTION"
          }
        }
      ]
    },
    "separate_approval_required": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "const": "MIGRATION_EXECUTION"
          }
        },
        {
          "contains": {
            "const": "CUTOVER"
          }
        },
        {
          "contains": {
            "const": "RETIREMENT"
          }
        },
        {
          "contains": {
            "const": "DELETION"
          }
        },
        {
          "contains": {
            "const": "SPEAR_WRITER_ACTIVATION"
          }
        }
      ]
    },
    "exceptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "packet_local_override_allowed",
        "implicit_override_allowed",
        "emergency_bypass_allowed",
        "change_method"
      ],
      "properties": {
        "packet_local_override_allowed": {
          "const": false
        },
        "implicit_override_allowed": {
          "const": false
        },
        "emergency_bypass_allowed": {
          "const": false
        },
        "change_method": {
          "type": "string",
          "minLength": 10
        }
      }
    }
  },
  "$defs": {
    "path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)(?!.*[\\x00-\\x1f\\x7f]).+$"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "exact": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          },
          "uniqueItems": true
        },
        "prefixes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path"
          },
          "uniqueItems": true
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "may"
      ],
      "properties": {
        "may": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true
        },
        "may_not": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true
        },
        "note": {
          "type": "string",
          "minLength": 5
        }
      }
    },
    "protected_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "level",
        "match",
        "normal_spear_mutation",
        "required_route",
        "controls"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "level": {
          "enum": [
            "HIGH",
            "CRITICAL"
          ]
        },
        "match": {
          "$ref": "#/$defs/match"
        },
        "normal_spear_mutation": {
          "type": "string",
          "minLength": 3
        },
        "required_route": {
          "type": "string",
          "minLength": 5
        },
        "controls": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true
        }
      }
    }
  }
}
