{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/agentic-warrant-receipt-v1.schema.json",
  "title": "Prime agentic warrant receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "receipt_id", "attempt_id", "nonce", "request_sha256", "executed_at", "warrant_id", "warrant_sha256", "observed_agent_id", "observed_credential_principal", "repository", "base_sha", "head_sha", "route", "actions", "paths", "approval_record_sha256s", "result", "error_code", "stop_point", "preview_sha256", "candidate_tree_sha256", "completed_checks", "evidence_sha256", "rollback", "forbidden_action_confirmation"],
  "properties": {
    "schema_version": {"const": "atlas.agentic-warrant-receipt.v1"},
    "receipt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "attempt_id": {"type": "string", "pattern": "^[A-Z0-9][A-Z0-9._-]{2,127}$"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9._-]{16,160}$"},
    "request_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "executed_at": {"type": "string", "minLength": 1, "maxLength": 40},
    "warrant_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "warrant_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "observed_agent_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "observed_credential_principal": {"type": "string", "minLength": 1, "maxLength": 160}, "repository": {"const": "Jktomy/atlas-prime"},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "head_sha": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "route": {"type": "string", "minLength": 1, "maxLength": 80}, "actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 40}},
    "paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 300}},
    "approval_record_sha256s": {"type": "array", "items": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}, "result": {"enum": ["SUCCESS", "REJECTED", "BLOCKED", "PARTIAL"]},
    "error_code": {"type": ["string", "null"], "maxLength": 120}, "stop_point": {"type": "string", "minLength": 1, "maxLength": 120},
    "preview_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate_tree_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "completed_checks": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 120}},
    "evidence_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "rollback": {"type": "string", "minLength": 1, "maxLength": 160},
    "forbidden_action_confirmation": {"type": "object", "additionalProperties": false, "required": ["direct_main", "force_push", "scope_expansion", "identity_impersonation", "standing_authority", "second_writer"], "properties": {
      "direct_main": {"const": false}, "force_push": {"const": false}, "scope_expansion": {"const": false}, "identity_impersonation": {"const": false},
      "standing_authority": {"const": false}, "second_writer": {"const": false}
    }}
  }
}
