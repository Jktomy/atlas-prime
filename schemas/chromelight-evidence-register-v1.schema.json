{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas.local/schemas/chromelight-evidence-register-v1.schema.json",
  "title": "Prime Chromelight evidence register v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "campaign", "gate", "gate_status", "observed_on", "promotion", "research_mode", "provider_activation", "repository_access_granted", "operator_account_readback", "sources", "evaluations", "unresolved_external_actions"],
  "properties": {
    "schema_version": {"const": "atlas.chromelight-evidence-register.v1"},
    "campaign": {"const": "RP-C03"},
    "gate": {"const": "CHROMELIGHT_EVIDENCE_RECONCILED"},
    "gate_status": {"const": "EVIDENCE_RECONCILED"},
    "observed_on": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"},
    "promotion": {"const": "NONE"},
    "research_mode": {"const": "PUBLIC_READ_ONLY"},
    "provider_activation": {"const": false},
    "repository_access_granted": {"const": false},
    "operator_account_readback": {"const": "NOT_PERFORMED"},
    "sources": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["source_id", "publisher", "title", "url", "observed_on", "supports"],
        "properties": {
          "source_id": {"type": "string", "pattern": "^GOOGLE-[A-Z0-9-]+$"},
          "publisher": {"const": "Google"},
          "title": {"type": "string", "minLength": 1, "maxLength": 180},
          "url": {"type": "string", "pattern": "^https://(developers\\.google\\.com|jules\\.google|blog\\.google|antigravity\\.google|codelabs\\.developers\\.google\\.com)/"},
          "observed_on": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}$"},
          "supports": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 120}}
        }
      }
    },
    "evaluations": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["evaluation_id", "provider_surface", "atlas_role", "surface_class", "availability", "operator_eligibility", "activation_state", "account_action_required", "repository_access_required", "stormlight", "mutation_route", "permanence_authority", "evidence_source_ids", "disposition", "blockers", "smallest_external_action"],
        "properties": {
          "evaluation_id": {"enum": ["GOOGLE-ELIGIBILITY", "GEMINI-SCOUT", "JULES", "ANTIGRAVITY-SHARDPLATE"]},
          "provider_surface": {"type": "string", "minLength": 1, "maxLength": 120},
          "atlas_role": {"type": "string", "minLength": 1, "maxLength": 80},
          "surface_class": {"enum": ["ACCOUNT_BOUNDARY", "RESEARCH_ROLE", "HOSTED_CODING_AGENT", "AI_ASSISTED_WORK_SURFACE"]},
          "availability": {"enum": ["DOCUMENTED_AVAILABLE", "DOCUMENTED_PREVIEW", "ATLAS_ROLE_ONLY"]},
          "operator_eligibility": {"enum": ["UNVERIFIED_REQUIRES_ACCOUNT_READBACK", "NOT_APPLICABLE_ATLAS_ROLE"]},
          "activation_state": {"const": "NOT_ACTIVATED"},
          "account_action_required": {"type": "boolean"},
          "repository_access_required": {"type": "boolean"},
          "stormlight": {"enum": ["CLOUD", "NONE"]},
          "mutation_route": {"const": false},
          "permanence_authority": {"const": false},
          "evidence_source_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^GOOGLE-[A-Z0-9-]+$"}},
          "disposition": {"enum": ["RECONCILED_UNVERIFIED", "EVALUATED_NOT_ACTIVATED", "ROLE_DEFINED_SURFACE_UNSELECTED"]},
          "blockers": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 180}},
          "smallest_external_action": {"type": "string", "minLength": 1, "maxLength": 240}
        }
      }
    },
    "unresolved_external_actions": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1, "maxLength": 240}}
  }
}
