{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "activation_authority": { "const": "ABSENT" },
    "authority_id": { "type": "string" },
    "base_sha": { "pattern": "^[0-9a-f]{40}$", "type": "string" },
    "bridge_mode": { "const": "COMPILE_ONLY" },
    "branch": { "type": "string" },
    "build_identity": { "type": "string" },
    "commit_message": { "type": "string" },
    "compile_receipt_filename": { "pattern": "^[A-Za-z0-9._-]+\\.json$", "type": "string" },
    "delete_authority_id": { "type": ["string", "null"] },
    "dispatch_authority": { "const": "ABSENT" },
    "execute_identity": { "type": "string" },
    "implementation_state": { "const": "SPEAR_BRIDGE_DISABLED" },
    "output_mission_filename": { "pattern": "^[A-Za-z0-9._-]+\\.json$", "type": "string" },
    "persistent_writer": { "const": "ABSENT" },
    "pr_body": { "type": "string" },
    "pr_title": { "type": "string" },
    "repository": { "const": "Jktomy/atlas-prime" },
    "route": { "const": "SPEAR_DIRECT" },
    "schema_version": { "const": "atlas-thread-engine-spear-weave-v1" },
    "standing_authority": { "const": "NO" },
    "stop_point": { "const": "MISSION_COMPILED" },
    "threads": {
      "items": { "type": "object" },
      "minItems": 1,
      "type": "array"
    },
    "weave_id": { "type": "string" }
  },
  "required": [
    "schema_version",
    "implementation_state",
    "bridge_mode",
    "route",
    "persistent_writer",
    "dispatch_authority",
    "activation_authority",
    "standing_authority",
    "weave_id",
    "authority_id",
    "build_identity",
    "execute_identity",
    "repository",
    "base_sha",
    "branch",
    "commit_message",
    "pr_title",
    "pr_body",
    "threads",
    "output_mission_filename",
    "compile_receipt_filename",
    "stop_point"
  ],
  "type": "object"
}
