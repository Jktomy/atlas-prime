{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Gate 7B Thread Engine Weave",
  "type": "object",
  "required": [
    "format_version",
    "weave_id",
    "engine_state",
    "mode",
    "base_fixture",
    "payload_root",
    "expected_base_tree_sha256",
    "threads",
    "expected_candidate_tree_sha256",
    "resume_from",
    "stop_boundary",
    "forbidden_actions",
    "receipt_name"
  ],
  "properties": {
    "format_version": { "const": "atlas-thread-engine-weave-v1" },
    "weave_id": { "type": "string", "minLength": 1 },
    "engine_state": { "const": "PILOT_DISABLED" },
    "mode": { "const": "FIXTURE_ONLY" },
    "base_fixture": { "type": "string" },
    "payload_root": { "type": "string" },
    "expected_base_tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "expected_candidate_tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "resume_from": { "type": "string" },
    "stop_boundary": { "const": "STOP" },
    "forbidden_actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "receipt_name": { "type": "string" },
    "threads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["thread_id", "operation", "path"],
        "properties": {
          "thread_id": { "type": "string", "minLength": 1 },
          "operation": { "enum": ["ADD", "REPLACE", "DELETE"] },
          "path": { "type": "string" },
          "source_sha256": { "type": "string" },
          "payload": { "type": "string" },
          "payload_sha256": { "type": "string" },
          "expected_output_sha256": { "type": "string" },
          "delete_authority_id": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
