{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Atlas Gate 7F Thread Engine Production Mission",
  "type": "object",
  "required": [
    "schema_version",
    "implementation_state",
    "adapter_mode",
    "persistent_writer",
    "activation_authority",
    "mission_id",
    "authority_id",
    "build_identity",
    "execute_identity",
    "mission_sha256",
    "repository",
    "remote_url",
    "base_sha",
    "branch",
    "commit_message",
    "pr_title",
    "pr_body",
    "declared_paths",
    "payload_root",
    "candidate_tree_sha256",
    "final_pathset_sha256",
    "source_blobs",
    "operations",
    "network_allowlist",
    "receipt_name",
    "stop_point"
  ],
  "properties": {
    "schema_version": { "const": "atlas-thread-engine-production-mission-v1" },
    "implementation_state": { "const": "THREAD_ENGINE_ACTIVE_MISSION_SCOPED" },
    "adapter_mode": { "const": "DRAFT_PR_ONLY" },
    "persistent_writer": { "const": "ABSENT" },
    "activation_authority": { "const": "MISSION_SCOPED" },
    "mission_id": { "type": "string", "minLength": 1 },
    "authority_id": { "type": "string", "minLength": 1 },
    "build_identity": { "type": "string", "minLength": 1 },
    "execute_identity": { "type": "string", "minLength": 1 },
    "mission_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "repository": { "const": "Jktomy/atlas-prime" },
    "remote_url": { "const": "https://github.com/Jktomy/atlas-prime.git" },
    "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "branch": { "type": "string" },
    "commit_message": { "type": "string", "minLength": 1 },
    "pr_title": { "type": "string", "minLength": 1 },
    "pr_body": { "type": "string", "minLength": 1 },
    "declared_paths": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "payload_root": { "type": "string" },
    "candidate_tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "final_pathset_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "source_blobs": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["thread_id", "operation", "path"],
        "properties": {
          "thread_id": { "type": "string", "minLength": 1 },
          "operation": { "enum": ["ADD", "REPLACE", "DELETE"] },
          "path": { "type": "string" },
          "payload": { "type": "string" },
          "source_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "payload_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "expected_output_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "delete_authority_id": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "lifecycle_profile": {
      "$ref": "../../../lifecycle/schemas/lifecycle-construction-profile-v1.schema.json"
    },
    "generated_checkpoint_profile": {
      "type": "object",
      "required": [
        "schema_id", "schema_version", "profile_id", "mission_id", "repository",
        "base_sha", "branch", "declared_paths", "source_blobs",
        "candidate_tree_sha256", "final_pathset_sha256", "operation_set_sha256",
        "source_fingerprint", "hash_register_path", "hash_register_sha256",
        "reconciliation_path", "reconciliation_sha256", "workflow_ref",
        "workflow_source_sha", "workflow_blob_sha", "workflow_run_id",
        "workflow_run_attempt", "event_name", "actor", "triggering_actor",
        "repository_owner", "credential_principal", "credential_mode",
        "replay_nonce_sha256", "public_clean_confirmation", "stop_point", "persistent_writer",
        "direct_main_write", "force_push", "automatic_ready", "automatic_merge",
        "workflow_dispatch", "repository_setting_mutation", "quest_promotion",
        "capability_promotion", "automatic_retry", "standing_authority"
      ],
      "properties": {
        "schema_id": { "const": "atlas.generated-checkpoint.profile" },
        "schema_version": { "const": "1.0.0" },
        "profile_id": { "const": "GENERATED_CHECKPOINT_V1" },
        "mission_id": { "type": "string", "pattern": "^[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
        "repository": { "const": "Jktomy/atlas-prime" },
        "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "branch": { "type": "string", "pattern": "^generated/checkpoint-[a-z0-9-]+-[0-9a-f]{12}$" },
        "declared_paths": { "type": "array", "minItems": 5, "maxItems": 5, "items": { "type": "string" } },
        "source_blobs": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{40}$" } },
        "candidate_tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "final_pathset_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "operation_set_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "source_fingerprint": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "hash_register_path": { "const": "evidence/hash-register.json" },
        "hash_register_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "reconciliation_path": { "const": "evidence/reconciliation.json" },
        "reconciliation_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "workflow_ref": { "const": "Jktomy/atlas-prime/.github/workflows/generated-checkpoint-publisher.yml@refs/heads/main" },
        "workflow_source_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "workflow_blob_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "workflow_run_id": { "type": "string", "pattern": "^[0-9]+$" },
        "workflow_run_attempt": { "type": "string", "pattern": "^[0-9]+$" },
        "event_name": { "const": "workflow_dispatch" },
        "actor": { "const": "Jktomy" },
        "triggering_actor": { "const": "Jktomy" },
        "repository_owner": { "const": "Jktomy" },
        "credential_principal": { "const": "github-actions[bot]" },
        "credential_mode": { "const": "GITHUB_TOKEN" },
        "replay_nonce_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "public_clean_confirmation": { "const": "PUBLIC_CLEAN_CONFIRMED" },
        "stop_point": { "const": "DRAFT_PR_READBACK" },
        "persistent_writer": { "const": "ABSENT" },
        "direct_main_write": { "const": false },
        "force_push": { "const": false },
        "automatic_ready": { "const": false },
        "automatic_merge": { "const": false },
        "workflow_dispatch": { "const": false },
        "repository_setting_mutation": { "const": false },
        "quest_promotion": { "const": false },
        "capability_promotion": { "const": false },
        "automatic_retry": { "const": false },
        "standing_authority": { "const": "NO" }
      },
      "additionalProperties": false
    },
    "delete_authority_id": { "type": "string" },
    "aegis_break_authority": {
      "type": "object",
      "required": [
        "route_identity",
        "authority_id",
        "operator",
        "github_operator_login",
        "repository",
        "base_sha",
        "branch",
        "declared_protected_paths",
        "source_blobs",
        "candidate_tree_sha256",
        "final_pathset_sha256",
        "operation_set_sha256",
        "stop_point",
        "persistent_writer",
        "direct_main_write",
        "force_push",
        "automatic_ready",
        "automatic_merge",
        "workflow_dispatch",
        "standing_authority"
      ],
      "properties": {
        "route_identity": { "const": "AEGIS_BREAK_PROTECTED_PATH_V1" },
        "authority_id": { "type": "string", "minLength": 1 },
        "operator": { "const": "Jayson" },
        "github_operator_login": { "const": "Jktomy" },
        "repository": { "const": "Jktomy/atlas-prime" },
        "base_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "branch": { "type": "string" },
        "declared_protected_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "source_blobs": {
          "type": "object",
          "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
        },
        "candidate_tree_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "final_pathset_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "operation_set_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "stop_point": { "const": "DRAFT_PR_READBACK" },
        "persistent_writer": { "const": "ABSENT" },
        "direct_main_write": { "const": false },
        "force_push": { "const": false },
        "automatic_ready": { "const": false },
        "automatic_merge": { "const": false },
        "workflow_dispatch": { "const": false },
        "standing_authority": { "const": "NO" }
      },
      "additionalProperties": false
    },
    "network_allowlist": {
      "const": [
        "https://github.com/Jktomy/atlas-prime.git",
        "https://api.github.com/repos/Jktomy/atlas-prime"
      ]
    },
    "receipt_name": { "type": "string", "pattern": "^[A-Za-z0-9._-]+\\.json$" },
    "stop_point": { "const": "DRAFT_PR_READBACK" }
  },
  "additionalProperties": false
}
